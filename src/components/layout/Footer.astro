---
import { SITE, waLink } from '../../data/site';
const wa = waLink();
---

<footer class="bg-jaga-dark text-gray-400 py-16 md:py-20 text-sm">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">

    <!-- Col 1: Brand -->
    <div class="flex flex-col items-start">
      <img
        src="/images/logo-horizontal.png"
        alt="JAGATRIP Logo"
        class="h-10 mb-6 brightness-0 invert opacity-90"
        width="180"
        height="40"
      />
      <p class="leading-relaxed text-gray-400 font-medium mb-6">
        JAGATRIP adalah program Edu-Tourism premium yang dirancang khusus untuk para
        praktisi pendidikan yang ingin melakukan benchmarking langsung ke sekolah-sekolah
        terbaik di dunia.
      </p>
      <div class="flex space-x-3">
        <a
          href="#"
          class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-jaga-orange transition-colors"
          aria-label="Instagram"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd"/>
          </svg>
        </a>
        <a
          href="#"
          class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-jaga-orange transition-colors"
          aria-label="TikTok"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 448 512" aria-hidden="true">
            <path d="M448,209.91a210.06,210.06,0,0,1-122.77-39.25V349.38A162.55,162.55,0,1,1,185,188.31V278.2a74.62,74.62,0,1,0,52.23,71.18V0l88,0a121.18,121.18,0,0,0,1.86,22.17h0A122.18,122.18,0,0,0,381,102.39a121.43,121.43,0,0,0,67,20.14Z"/>
          </svg>
        </a>
        <a
          href="#"
          class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-jaga-orange transition-colors"
          aria-label="Facebook"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Col 2: Layanan -->
    <div>
      <h4 class="text-white font-bold text-lg mb-6">Layanan</h4>
      <ul class="space-y-4 font-medium text-gray-400 text-sm md:text-base">
        <li><a href="/#layanan" class="hover:text-white transition flex items-center"><span class="text-jaga-orange mr-3">▪</span> Field Learning</a></li>
        <li><a href="/#layanan" class="hover:text-white transition flex items-center"><span class="text-jaga-orange mr-3">▪</span> Workshop Eksklusif</a></li>
        <li><a href="/#layanan" class="hover:text-white transition flex items-center"><span class="text-jaga-orange mr-3">▪</span> Dialog Terbuka</a></li>
        <li><a href="/#layanan" class="hover:text-white transition flex items-center"><span class="text-jaga-orange mr-3">▪</span> City Tour Edukatif</a></li>
        <li><a href="/#layanan" class="hover:text-white transition flex items-center"><span class="text-jaga-orange mr-3">▪</span> Networking Praktisi</a></li>
      </ul>
    </div>

    <!-- Col 3: Kontak -->
    <div>
      <h4 class="text-white font-bold text-lg mb-6">Kontak</h4>
      <ul class="space-y-5 font-medium text-gray-400 text-sm md:text-base">
        <li>
          <a href={wa} target="_blank" rel="noopener noreferrer" class="flex items-center hover:text-white transition group">
            <svg class="w-5 h-5 mr-4 text-gray-500 group-hover:text-jaga-orange flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <span>{SITE.waDisplay}</span>
          </a>
        </li>
        <li>
          <a href={`mailto:${SITE.email}`} class="flex items-center hover:text-white transition group">
            <svg class="w-5 h-5 mr-4 text-gray-500 group-hover:text-jaga-orange flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <span>{SITE.email}</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- Col 4: Value -->
    <div>
      <h4 class="text-white font-bold text-lg mb-6">Value Kami</h4>
      <ul class="space-y-4 font-medium text-gray-400 text-sm md:text-base">
        <li><a href="/#why" class="hover:text-white transition flex items-center"><span class="text-jaga-orange mr-3">▪</span> Sistem Kelas Dunia</a></li>
        <li><a href="/#why" class="hover:text-white transition flex items-center"><span class="text-jaga-orange mr-3">▪</span> Guru Menginspirasi</a></li>
        <li><a href="/#why" class="hover:text-white transition flex items-center"><span class="text-jaga-orange mr-3">▪</span> Teknologi Relevan</a></li>
        <li><a href="/#why" class="hover:text-white transition flex items-center"><span class="text-jaga-orange mr-3">▪</span> Jaringan Profesional</a></li>
        <li><a href="/#why" class="hover:text-white transition flex items-center"><span class="text-jaga-orange mr-3">▪</span> Sertifikasi Resmi</a></li>
      </ul>
    </div>

  </div>

  <div class="max-w-7xl mx-auto px-6 mt-16 pt-8 border-t border-gray-800 text-center text-gray-500 font-medium text-xs md:text-sm">
    <p>&copy; {new Date().getFullYear()} {SITE.legalName}. All rights reserved.</p>
  </div>
</footer>
