---
import { getCollection } from 'astro:content';

const trips = (await getCollection('trips')).sort((a, b) => a.data.monthNum - b.data.monthNum);
---

<section id="konsultasi" class="py-20 md:py-28 bg-linear-to-br from-jaga-orange to-orange-600 text-white relative overflow-hidden">

  <!-- Decorative blobs -->
  <div class="absolute top-10 right-10 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 left-10 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Left: copy -->
      <div>
        <span class="inline-block bg-white/20 backdrop-blur-sm border border-white/30 text-white font-black text-xs md:text-sm uppercase tracking-[0.3em] px-5 py-2 rounded-full mb-6">
          🎯 Konsultasi Gratis
        </span>

        <h2 class="text-3xl md:text-5xl font-black tracking-tight leading-tight mb-6">
          Mau diskusi dulu sebelum daftar? <span class="italic text-yellow-200">Gratis!</span>
        </h2>

        <p class="text-lg md:text-xl text-orange-50 leading-relaxed mb-8">
          Isi form di samping — tim JAGATRIP akan menghubungimu langsung via WhatsApp dalam <strong class="text-white">1×24 jam</strong> untuk berdiskusi denganmu.
        </p>

        <ul class="space-y-3 text-base text-orange-50">
          <li class="flex items-center gap-3">
            <span class="shrink-0 w-7 h-7 rounded-full bg-white/20 flex items-center justify-center text-white font-black text-sm">✓</span>
            Tanpa komitmen — diskusi dulu sampai kamu yakin
          </li>
          <li class="flex items-center gap-3">
            <span class="shrink-0 w-7 h-7 rounded-full bg-white/20 flex items-center justify-center text-white font-black text-sm">✓</span>
            Konsultasi langsung dengan admin jagatrip
          </li>
          <li class="flex items-center gap-3">
            <span class="shrink-0 w-7 h-7 rounded-full bg-white/20 flex items-center justify-center text-white font-black text-sm">✓</span>
            Dapatkan program sesuai kebutuhan
          </li>
        </ul>
      </div>

      <!-- Right: form -->
      <div class="bg-white text-gray-900 rounded-4xl p-6 md:p-8 shadow-[0_25px_60px_rgba(0,0,0,0.25)]">
        <p class="text-xl md:text-2xl font-black text-gray-900 mb-1">Konsultasi Gratis Sekarang</p>
        <p class="text-sm text-gray-500 mb-6">Tim kami akan menghubungi Anda dalam 1×24 jam.</p>

        <form id="konsultasi-form" novalidate class="space-y-3">
          <div>
            <label for="f-nama" class="sr-only">Nama Lengkap</label>
            <input
              id="f-nama" name="nama" type="text" required
              placeholder="Nama Lengkap*"
              class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-jaga-orange focus:outline-none text-gray-900 placeholder:text-gray-400 text-sm font-medium transition-colors"
            />
          </div>
          <div>
            <label for="f-sekolah" class="sr-only">Nama Sekolah/Instansi</label>
            <input
              id="f-sekolah" name="sekolah" type="text" required
              placeholder="Nama Sekolah / Instansi*"
              class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-jaga-orange focus:outline-none text-gray-900 placeholder:text-gray-400 text-sm font-medium transition-colors"
            />
          </div>
          <div>
            <label for="f-wa" class="sr-only">No. WhatsApp</label>
            <input
              id="f-wa" name="wa" type="tel" required inputmode="numeric"
              placeholder="No. WhatsApp* (contoh: 081234567890)"
              class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-jaga-orange focus:outline-none text-gray-900 placeholder:text-gray-400 text-sm font-medium transition-colors"
            />
          </div>
          <div>
            <label for="f-program" class="sr-only">Program Tujuan</label>
            <select
              id="f-program" name="program" required
              class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-jaga-orange focus:outline-none text-gray-900 text-sm font-medium bg-white transition-colors"
            >
              <option value="">Program Tujuan*</option>
              {trips.map(trip => (
                <option value={trip.data.destination}>{trip.data.destination} — {trip.data.month} {trip.data.year}</option>
              ))}
              <option value="Belum Pasti">Belum Pasti / Konsultasi Dulu</option>
            </select>
          </div>
          <div>
            <label for="f-peserta" class="sr-only">Estimasi Jumlah Peserta</label>
            <select
              id="f-peserta" name="peserta" required
              class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-jaga-orange focus:outline-none text-gray-900 text-sm font-medium bg-white transition-colors"
            >
              <option value="">Estimasi Jumlah Peserta*</option>
              <option value="1-9 orang">1–9 orang (Individu / Kecil)</option>
              <option value="10-20 orang">10–20 orang</option>
              <option value="21-50 orang">21–50 orang</option>
              <option value="51-100 orang">51–100 orang</option>
              <option value="100+ orang">100+ orang</option>
            </select>
          </div>

          <button
            type="submit"
            class="w-full bg-jaga-orange hover:bg-jaga-orange-600 text-white font-black text-base md:text-lg py-4 rounded-full shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-0.5 mt-2"
          >
            Kirim & Chat WhatsApp →
          </button>

          <p class="text-xs text-gray-400 text-center mt-3 leading-relaxed">
            🔒 Data Anda aman. Form ini akan membuka WhatsApp dengan pesan pre-filled.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border-width: 0;
  }
</style>

<script>
  import { initKonsultasiForm } from '../../../lib/form-handler';
  initKonsultasiForm();
</script>
