---
import { getCollection } from 'astro:content';

const trips = (await getCollection('trips'))
  .sort((a, b) => a.data.monthNum - b.data.monthNum);

const monthShort: Record<number, string> = {
  1: 'Jan',
  2: 'Feb',
  3: 'Mar',
  4: 'Apr',
  5: 'Mei',
  6: 'Juni',
  7: 'Juli',
  8: 'Agust',
  9: 'Sept',
  10: 'Okt',
  11: 'Nov',
  12: 'Des',
};

function formatScheduleRange(start: Date, end: Date): string {
  const startDay = start.getUTCDate();
  const endDay = end.getUTCDate();
  const m = monthShort[start.getUTCMonth() + 1];
  return `${startDay}-${endDay} ${m}`;
}

// Display name override for the agenda table destination column
const destinationDisplay: Record<string, string> = {
  'jogja': 'Jogja',
  'triple-country-asean': '3 Negara (MY, TH, SG)',
};
---

<section id="agenda" class="py-24 bg-jaga-bg" aria-labelledby="agenda-heading">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-4xl mx-auto mb-16">
      <h2 id="agenda-heading" class="text-4xl md:text-6xl font-black text-gray-900 mb-4 tracking-tight">AGENDA 2026</h2>
      <p class="text-xl md:text-2xl text-jaga-orange font-bold mb-3">7 Destinasi, 7 Pengalaman Tak Terlupakan.</p>
      <span class="inline-block bg-gray-900 text-white font-black text-xs md:text-sm uppercase tracking-widest px-5 py-2 rounded-full">
        ✨ INSIDER SERIES 2026 ✨
      </span>
    </div>

    <div class="overflow-hidden bg-white rounded-3xl shadow-xl border border-gray-100">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[900px]">
          <thead>
            <tr class="bg-gray-900 text-white">
              <th class="py-5 px-6 font-bold text-sm uppercase tracking-wider whitespace-nowrap">Jadwal</th>
              <th class="py-5 px-6 font-bold text-sm uppercase tracking-wider">Destinasi</th>
              <th class="py-5 px-6 font-bold text-sm uppercase tracking-wider text-center">Durasi</th>
              <th class="py-5 px-6 font-bold text-sm uppercase tracking-wider">Fokus Program</th>
            </tr>
          </thead>
          <tbody class="text-gray-700 divide-y divide-gray-100">
            {trips.map((trip) => {
              const dest = destinationDisplay[trip.data.slug] ?? trip.data.destination;
              const isInternational = trip.data.category === 'Internasional';
              const isTriple = trip.data.slug === 'triple-country-asean';
              return (
                <tr class="hover:bg-orange-50/50 transition-colors">
                  <td class="py-5 px-6 align-top whitespace-nowrap">
                    <div class="font-bold text-gray-900 text-lg">{formatScheduleRange(trip.data.dateStart, trip.data.dateEnd)}</div>
                    <div class="text-sm font-medium text-gray-500">{trip.data.month}</div>
                  </td>
                  <td class="py-5 px-6 align-top">
                    <a href={`/trips/${trip.data.slug}`} class="font-bold text-lg text-jaga-orange mb-2 block hover:underline">{dest}</a>
                    {isInternational ? (
                      <span class="inline-block px-3 py-1 bg-blue-50 border border-blue-200 text-blue-700 text-xs font-bold rounded-full">Internasional</span>
                    ) : (
                      <span class="inline-block px-3 py-1 bg-green-50 border border-green-200 text-green-700 text-xs font-bold rounded-full">Lokal</span>
                    )}
                  </td>
                  <td class={`py-5 px-6 text-center font-bold align-top${isTriple ? ' whitespace-nowrap' : ''}`}>
                    {trip.data.duration}
                    {isTriple && (
                      <>
                        <br /><span class="text-xs font-normal text-gray-500">(5H + 2H PP)</span>
                      </>
                    )}
                  </td>
                  <td class="py-5 px-6 leading-relaxed font-medium align-top text-gray-600">{trip.data.focus}.</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
