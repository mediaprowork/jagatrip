---
import { waLink } from '../../../data/site';
const wa = waLink('Malaysia-Thailand', '24-28 Juni 2026');
---

<section class="py-20 md:py-28 bg-jaga-bg border-t border-gray-200">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Header outside card -->
    <div class="text-center mb-8">
      <span class="inline-block bg-jaga-orange/10 text-jaga-orange font-black text-xs md:text-sm uppercase tracking-[0.3em] px-5 py-2 rounded-full">
        ✨ Coming Up Event ✨
      </span>
    </div>

    <div class="bg-linear-to-br from-jaga-orange to-orange-600 rounded-4xl p-10 md:p-16 shadow-[0_25px_60px_rgba(255,107,53,0.35)] text-white text-center relative overflow-hidden border-4 border-white/20">

      <!-- Decorative dots -->
      <div class="absolute top-8 right-8 w-24 h-24 bg-white/10 rounded-full blur-2xl"></div>
      <div class="absolute bottom-8 left-8 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>

      <div class="relative z-10">
        <!-- Heading -->
        <p class="text-base md:text-lg font-bold text-orange-100 mb-2 tracking-widest uppercase">
          JAGATRIP GOES TO
        </p>
        <h2 class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight leading-none mb-4">
          MALAYSIA<span class="text-yellow-200"> · </span>THAILAND
        </h2>
        <p class="text-xl md:text-2xl font-bold text-orange-50 max-w-2xl mx-auto mb-10 leading-snug">
          Buka Rahasia Sistem Pendidikan Malaysia &amp; Thailand
        </p>

        <!-- Date -->
        <div class="inline-block bg-white text-jaga-orange font-black text-2xl md:text-3xl px-8 py-3 rounded-2xl shadow-lg mb-6">
          📅 24–28 Juni 2026
        </div>

        <!-- Tagline -->
        <p class="text-lg md:text-xl font-bold text-orange-50 max-w-2xl mx-auto mb-10 leading-relaxed">
          Ekspedisi 5 hari yang mengubah sistem pendidikan sekolahmu!
        </p>

        <!-- CTA -->
        <a
          href="#daftar"
          class="inline-flex items-center gap-2 bg-gray-900 hover:bg-black text-white font-black text-base md:text-lg px-10 py-4 rounded-full shadow-xl hover:shadow-2xl transition-all transform hover:-translate-y-1"
        >
          Amankan Kursi Sekarang →
        </a>
      </div>
    </div>
  </div>
</section>
