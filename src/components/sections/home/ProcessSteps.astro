---
const steps = [
  {
    num: '01',
    title: 'Konsultasi',
    desc: 'Hubungi admin via WhatsApp, ceritakan kebutuhanmu',
  },
  {
    num: '02',
    title: 'Konfirmasi & DP',
    desc: 'Bayar DP 50% untuk mengamankan seat-mu',
  },
  {
    num: '03',
    title: 'Pre-Trip Briefing',
    desc: 'Terima detail program, checklist persiapan, dan informasi lengkap',
  },
  {
    num: '04',
    title: 'Perjalanan Berlangsung',
    desc: 'Ikuti program penuh: sekolah, workshop, networking, city tour',
  },
  {
    num: '05',
    title: 'Pasca-Trip Network',
    desc: 'Bergabung ke alumni community JAGATRIP dan terapkan insight',
  },
];
---

<section
  class="section process-section"
  aria-labelledby="process-title"
>
  <div class="container">
    <!-- Header -->
    <div class="process-header reveal">
      <span class="eyebrow">CARA IKUT</span>
      <h2 id="process-title" class="section-title">
        Dari Konsultasi hingga <span class="italic">Pulang Bawa Insight</span>
      </h2>
      <p class="process-sub">
        Proses mudah, transparan, dan didampingi dari awal sampai akhir.
      </p>
    </div>

    <!-- Vertical timeline -->
    <div class="timeline-wrap">
      {steps.map((step, i) => (
        <div class="timeline-item reveal" style={i % 2 === 1 ? 'margin-left: 24px;' : ''}>
          {/* Connector line above (except first) */}
          {i > 0 && (
            <div class="timeline-connector" aria-hidden="true"></div>
          )}

          <div class="step-card">
            {/* Step number circle */}
            <div class="step-circle" aria-hidden="true">
              {step.num}
            </div>

            {/* Step content */}
            <div class="step-content">
              <h3 class="step-title">{step.title}</h3>
              <p class="step-desc">{step.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section {
    background: var(--color-paper);
  }

  /* Header */
  .process-header {
    text-align: center;
    max-width: 720px;
    margin-inline: auto;
    margin-bottom: 64px;
  }

  .process-sub {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-grey);
    margin-top: 16px;
  }

  /* Timeline container */
  .timeline-wrap {
    max-width: 800px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Each item wrapper */
  .timeline-item {
    position: relative;
    transition: margin-left 0.3s ease;
  }

  /* Connector line */
  .timeline-connector {
    width: 2px;
    height: 32px;
    background: rgba(255, 107, 53, 0.28);
    margin-left: 27px; /* center below circle (56px / 2 = 28px, minus 1px for border) */
    margin-bottom: 0;
  }

  /* Step card */
  .step-card {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    background: var(--color-white);
    border-radius: 20px;
    padding: 24px 28px;
    border: 1px solid var(--color-grey-light);
    transition: border-color 0.25s ease,
                box-shadow 0.25s ease,
                transform 0.25s ease;
  }

  .step-card:hover {
    border-color: rgba(255, 107, 53, 0.35);
    box-shadow: 0 8px 28px rgba(255, 107, 53, 0.09);
    transform: translateY(-2px);
  }

  /* Step number circle */
  .step-circle {
    width: 56px;
    height: 56px;
    min-width: 56px;
    border-radius: 50%;
    background: var(--color-orange);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 900;
    font-style: italic;
    line-height: 1;
    box-shadow: 0 4px 16px rgba(255, 107, 53, 0.35);
    flex-shrink: 0;
  }

  /* Step text content */
  .step-content {
    padding-top: 4px;
  }

  .step-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .step-desc {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-grey);
    margin: 0;
  }

  /* Mobile: remove odd offsets */
  @media (max-width: 640px) {
    .timeline-item {
      margin-left: 0 !important;
    }

    .step-card {
      padding: 20px 20px;
      gap: 18px;
    }

    .step-circle {
      width: 48px;
      height: 48px;
      min-width: 48px;
      font-size: 16px;
    }

    .timeline-connector {
      margin-left: 23px;
    }
  }
</style>
