---
import { waLink } from '../../../data/site';
const wa = waLink('Malaysia-Thailand', '24-28 Juni 2026');
const waConsult = waLink('Konsultasi Gratis');
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <p class="text-gray-700 text-2xl md:text-3xl font-black mb-8 tracking-tight uppercase">SAATNYA KAMU AMBIL LANGKAH NYATA</p>

    <div class="bg-jaga-orange rounded-4xl p-10 md:p-14 shadow-xl text-white mb-8">
      <h2 class="text-2xl md:text-3xl font-black mb-3 leading-tight">
        Ekspedisi Benchmarking Internasional
      </h2>
      <p class="text-xl md:text-2xl font-bold text-orange-100 leading-snug mb-8">
        Mengulik Rahasia Sekolah Kelas Dunia yang Tidak Diajarkan di Seminar Manapun
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#daftar"
          class="group flex items-center justify-center gap-2 w-full sm:w-auto bg-white text-jaga-orange font-bold text-lg px-10 py-4 rounded-full shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1"
        >
          Daftar Sekarang
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a
          href={waConsult}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-full sm:w-auto border-2 border-white text-white hover:bg-white hover:text-jaga-orange font-bold text-lg px-10 py-4 rounded-full transition-all"
        >
          💬 Konsultasi Gratis
        </a>
      </div>
    </div>
  </div>
</section>
