---
import { waLink } from '../../../data/site';
const wa = waLink('Malaysia-Thailand', '24-28 Juni 2026');
---

<section class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden bg-jaga-bg">
  <div class="absolute inset-0 z-0 opacity-10 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-jaga-orange via-transparent to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 flex flex-col lg:flex-row items-center gap-16">

    <div class="lg:w-1/2 text-center lg:text-left">
      <span class="inline-block py-2 px-5 rounded-full bg-jaga-orange/10 text-jaga-orange font-bold text-sm md:text-base mb-6 tracking-widest uppercase shadow-sm">
        Ekspedisi Benchmarking Internasional
      </span>

      <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-gray-900 tracking-tight leading-[1.1] mb-6">
        JAGATRIP TO <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-jaga-orange to-orange-400">
          MALAYSIA - THAILAND
        </span>
      </h1>

      <p class="text-xl md:text-2xl text-gray-700 mb-6 font-semibold">
        Edukasi Wisata dan jelajah Sekolah di Malaysia dan Thailand
      </p>

      <p class="text-lg md:text-xl text-gray-500 mb-10 leading-relaxed">
        Temukan rahasia manajemen sekolah kelas dunia yang belum pernah terungkap ke publik —
        langsung dari sumbernya.
      </p>

      <a
        href="#pricing"
        class="inline-block bg-jaga-orange hover:bg-[#e55a2b] text-white px-10 py-5 rounded-full font-bold text-lg shadow-[0_10px_30px_rgba(255,107,53,0.3)] hover:shadow-[0_15px_40px_rgba(255,107,53,0.4)] transition-all duration-300 transform hover:-translate-y-1"
      >
        Amankan Kursi Sekarang
      </a>
    </div>

    <div class="lg:w-1/2 w-full max-w-md mx-auto lg:max-w-none">
      <a
        href={wa}
        target="_blank"
        rel="noopener noreferrer"
        class="block relative w-full aspect-[4/5] rounded-[2.5rem] bg-white shadow-2xl border border-gray-100 overflow-hidden group"
      >
        <!-- Gradient bg -->
        <div class="absolute inset-0 bg-gradient-to-tr from-jaga-orange to-orange-300 opacity-10 group-hover:opacity-20 transition-opacity duration-500"></div>

        <!-- Hero poster content -->
        <div class="relative z-10 h-full flex flex-col justify-between p-10 md:p-12">

          <!-- Top: badge -->
          <div class="flex items-center justify-between">
            <img src="/images/logo-icon.png" alt="" class="h-10 w-auto" />
            <span class="text-xs font-bold uppercase tracking-widest text-gray-400">Insider 2026</span>
          </div>

          <!-- Middle: program name -->
          <div class="text-center">
            <p class="text-sm font-bold uppercase tracking-[0.2em] text-jaga-orange mb-3">JAGATRIP TO</p>
            <h2 class="text-4xl md:text-5xl font-black text-gray-900 leading-none mb-4">
              MALAYSIA<br/>
              <span class="text-jaga-orange">&amp;</span> THAILAND
            </h2>
            <p class="text-3xl">🇲🇾 🇹🇭</p>
          </div>

          <!-- Bottom: stats + price -->
          <div>
            <div class="grid grid-cols-3 gap-2 mb-5 pb-5 border-b border-gray-200">
              <div class="text-center">
                <p class="text-2xl md:text-3xl font-black text-jaga-orange leading-none">5</p>
                <p class="text-xs font-bold uppercase tracking-wider text-gray-500 mt-1">Hari</p>
              </div>
              <div class="text-center border-x border-gray-200">
                <p class="text-2xl md:text-3xl font-black text-jaga-orange leading-none">2</p>
                <p class="text-xs font-bold uppercase tracking-wider text-gray-500 mt-1">Negara</p>
              </div>
              <div class="text-center">
                <p class="text-2xl md:text-3xl font-black text-jaga-orange leading-none">10+</p>
                <p class="text-xs font-bold uppercase tracking-wider text-gray-500 mt-1">Sekolah</p>
              </div>
            </div>
            <div class="flex items-end justify-between">
              <div>
                <p class="text-xs font-bold uppercase tracking-wider text-gray-500">Tanggal</p>
                <p class="text-sm font-bold text-gray-900">24 – 28 Juni 2026</p>
              </div>
              <div class="text-right">
                <p class="text-xs font-bold uppercase tracking-wider text-gray-500">Early Bird</p>
                <p class="text-2xl font-black text-jaga-orange">Rp 7.9Jt</p>
              </div>
            </div>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>
