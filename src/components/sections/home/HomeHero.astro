---
import HeroBadge from '../../ui/HeroBadge.astro';
import Button    from '../../ui/Button.astro';
import Logo      from '../../brand/Logo.astro';
import { waLink, SITE } from '../../../data/site';
---

<section
  class="hero-section"
  aria-label="Hero — JAGATRIP Insider Series 2026"
>
  <!-- Background grid lines (editorial) -->
  <div class="hero-grid-lines" aria-hidden="true"></div>

  <div class="container">
    <div class="hero-layout">

      <!-- ─── LEFT: Text content ─── -->
      <div class="hero-text">
        <HeroBadge text="JAGATRIP INSIDER SERIES 2026" />

        <h1 class="hero-h1">
          Buka Jendela <span class="highlight">Dunia</span><br />
          untuk Generasi<br />Indonesia.
        </h1>

        <p class="hero-lead">
          Program Edu-Tourism premium untuk praktisi pendidikan yang ingin
          benchmarking langsung ke sekolah-sekolah terbaik dunia.
          <strong>Bukan studi banding biasa.</strong>
        </p>

        <div class="hero-ctas">
          <Button href="#agenda" variant="primary" size="lg">
            Lihat Agenda 2026 →
          </Button>
          <Button
            href={waLink()}
            variant="wa"
            size="lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span aria-hidden="true">💬</span> Konsultasi WhatsApp
          </Button>
        </div>

        <div class="hero-trust">
          <span class="trust-item">
            <span class="trust-check" aria-hidden="true">✓</span>
            Tour Leader Bersertifikat
          </span>
          <span class="trust-item">
            <span class="trust-check" aria-hidden="true">✓</span>
            Asuransi Lengkap
          </span>
          <span class="trust-item">
            <span class="trust-check" aria-hidden="true">✓</span>
            Workshop Eksklusif
          </span>
        </div>
      </div>

      <!-- ─── RIGHT: Brand editorial showcase ─── -->
      <div class="hero-visual" aria-hidden="true">

        <!-- Main credential card — ID card / business card style -->
        <div class="brand-card">
          <div class="brand-card-top">
            <Logo variant="icon" height={36} />
            <span class="brand-card-tag">INSIDER SERIES 2026</span>
          </div>

          <div class="brand-card-mid">
            <p class="brand-card-dest">
              MALAYSIA<br />&amp; THAILAND
            </p>
            <p class="brand-card-flags">🇲🇾🇹🇭</p>
          </div>

          <div class="brand-card-bot">
            <div>
              <p class="brand-card-meta">TANGGAL</p>
              <p class="brand-card-val">24 – 28 JUNI 2026</p>
            </div>
            <div>
              <p class="brand-card-meta">EARLY BIRD</p>
              <p class="brand-card-price">Rp 7.9jt</p>
            </div>
          </div>

          <!-- Watermark number -->
          <span class="brand-card-wm" aria-hidden="true">01</span>
        </div>

        <!-- Social proof pill -->
        <div class="social-pill">
          <div class="avatars-mini">
            <span class="av" style="background:var(--color-grad-avatar-1)">BH</span>
            <span class="av" style="background:var(--color-grad-avatar-3)">SR</span>
            <span class="av" style="background:var(--color-grad-avatar-2)">AF</span>
            <span class="av" style="background:var(--color-grad-avatar-4)">RK</span>
          </div>
          <div>
            <p class="social-count">47+ praktisi daftar</p>
            <p class="social-sub">Kursi terbatas</p>
          </div>
          <span class="live-dot" aria-hidden="true"></span>
        </div>

        <!-- Quote badge -->
        <div class="quote-badge">
          <p class="quote-stars" aria-hidden="true">★★★★★</p>
          <p class="quote-text">
            "Workshop dengan praktisi internasional benar-benar mengubah cara pandang tim kami."
          </p>
          <p class="quote-author">— Bapak Hidayat, Kepala Sekolah</p>
        </div>

        <!-- Trip count badge -->
        <div class="count-badge">
          <p class="count-num">7</p>
          <p class="count-label">Destinasi<br />2026</p>
        </div>

        <!-- Decorative -->
        <span class="hero-deco-plane" aria-hidden="true">✈️</span>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .hero-section {
    background: var(--color-paper);
    position: relative;
    overflow: hidden;
    padding-block: 72px 96px;
  }

  /* Editorial grid lines background */
  .hero-grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,107,53,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,107,53,0.04) 1px, transparent 1px);
    background-size: 80px 80px;
    pointer-events: none;
  }

  /* Radial glow */
  .hero-section::after {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,107,53,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Layout ── */
  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── Text side ── */
  .hero-lead {
    font-size: clamp(16px, 1.8vw, 18px);
    line-height: 1.75;
    color: var(--color-grey);
    max-width: 480px;
    margin-bottom: 36px;
  }

  .hero-lead strong {
    color: var(--color-ink);
    font-weight: 700;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 36px;
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-grey);
  }

  .trust-check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-orange-light);
    color: var(--color-orange);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ── Visual side ── */
  .hero-visual {
    position: relative;
    height: 500px;
  }

  /* ─ Main brand credential card ─ */
  .brand-card {
    position: absolute;
    top: 0;
    left: 0;
    right: 40px;
    background: linear-gradient(135deg, #FF6B35 0%, #E85A2C 100%);
    border-radius: 24px;
    padding: 28px 32px;
    box-shadow:
      0 24px 60px rgba(255,107,53,0.35),
      0 8px 20px rgba(0,0,0,0.12);
    overflow: hidden;
    z-index: 2;
  }

  .brand-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .brand-card-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    background: rgba(255,255,255,0.12);
    padding: 4px 10px;
    border-radius: 100px;
  }

  .brand-card-mid {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .brand-card-dest {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 900;
    color: white;
    line-height: 1.05;
    letter-spacing: -1px;
    margin: 0;
  }

  .brand-card-flags {
    font-size: 36px;
    line-height: 1;
    margin: 0;
  }

  .brand-card-bot {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 20px;
  }

  .brand-card-meta {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin: 0 0 4px;
  }

  .brand-card-val {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    color: white;
    margin: 0;
  }

  .brand-card-price {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 900;
    font-style: italic;
    color: white;
    margin: 0;
    text-align: right;
  }

  /* Watermark number */
  .brand-card-wm {
    position: absolute;
    bottom: -20px;
    right: 20px;
    font-family: var(--font-display);
    font-size: 120px;
    font-weight: 900;
    font-style: italic;
    color: rgba(255,255,255,0.08);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  /* ─ Social proof pill ─ */
  .social-pill {
    position: absolute;
    bottom: 60px;
    left: 20px;
    right: 20px;
    background: white;
    border-radius: 16px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
    box-shadow: 0 16px 40px rgba(0,0,0,0.10);
    z-index: 4;
  }

  .avatars-mini {
    display: flex;
    flex-shrink: 0;
  }

  .av {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 2px solid white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    color: white;
    margin-left: -8px;
    flex-shrink: 0;
  }

  .av:first-child { margin-left: 0; }

  .social-count {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0 0 2px;
  }

  .social-sub {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-grey);
    margin: 0;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10B981;
    margin-left: auto;
    flex-shrink: 0;
    animation: pulse 2s infinite;
  }

  /* ─ Testimonial quote badge ─ */
  .quote-badge {
    position: absolute;
    top: 180px;
    right: 0;
    width: 200px;
    background: var(--color-ink);
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.18);
    z-index: 3;
  }

  .quote-stars {
    color: #FBBF24;
    font-size: 12px;
    letter-spacing: 2px;
    margin: 0 0 8px;
  }

  .quote-text {
    font-family: var(--font-display);
    font-size: 12px;
    font-style: italic;
    color: rgba(255,255,255,0.88);
    line-height: 1.55;
    margin: 0 0 10px;
  }

  .quote-author {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    color: var(--color-orange);
    letter-spacing: 1px;
    margin: 0;
  }

  /* ─ Trip count badge ─ */
  .count-badge {
    position: absolute;
    bottom: 0;
    right: 0;
    background: var(--color-orange-light);
    border-radius: 20px;
    padding: 20px 24px;
    text-align: center;
    border: 2px solid var(--color-orange);
    z-index: 3;
  }

  .count-num {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 900;
    font-style: italic;
    color: var(--color-orange);
    line-height: 1;
    margin: 0 0 4px;
  }

  .count-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-orange-dark);
    line-height: 1.4;
    margin: 0;
  }

  /* ─ Decorative plane ─ */
  .hero-deco-plane {
    position: absolute;
    bottom: 80px;
    left: -10px;
    font-size: 80px;
    opacity: 0.08;
    pointer-events: none;
    transform: rotate(-20deg);
    z-index: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 968px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 56px;
    }

    .hero-visual {
      height: 420px;
    }

    .quote-badge {
      top: 160px;
      width: 180px;
    }
  }

  @media (max-width: 640px) {
    .hero-visual {
      height: 380px;
    }

    .brand-card {
      right: 0;
    }

    .quote-badge {
      display: none;
    }
  }
</style>
