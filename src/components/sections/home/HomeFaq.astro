---
import { getCollection } from 'astro:content';
import Button from '../../ui/Button.astro';

const allFaqs = await getCollection('faqs');
const faqs = allFaqs
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 7);
---

<section
  class="section"
  style="background: var(--color-white);"
  aria-labelledby="faq-title"
>
  <div class="container">
    <!-- Header -->
    <div style="text-align: center; max-width: 720px; margin-inline: auto; margin-bottom: 56px;">
      <span class="eyebrow">FAQ</span>
      <h2 id="faq-title" class="section-title" style="margin-bottom: 16px;">
        Ada Pertanyaan? Kami Jawab <span class="italic">Semuanya di Sini.</span>
      </h2>
      <p style="
        font-family: var(--font-body);
        font-size: 16px;
        color: var(--color-grey);
        line-height: 1.6;
      ">
        Masih ada pertanyaan? Hubungi admin kami via WhatsApp.
      </p>
    </div>

    <!-- FAQ List -->
    <div
      style="max-width: 800px; margin-inline: auto;"
      role="list"
      aria-label="Daftar pertanyaan yang sering ditanyakan"
    >
      {faqs.map((faq) => (
        <div
          class="faq-item"
          id={`faq-${faq.id}`}
          role="listitem"
        >
          <button
            class="faq-question"
            aria-expanded="false"
            aria-controls={`faq-answer-${faq.id}`}
          >
            <span>{faq.data.question}</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div
            class="faq-answer"
            id={`faq-answer-${faq.id}`}
            role="region"
          >
            <p>{faq.data.answer}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div style="text-align: center; margin-top: 48px;">
      <p style="
        font-family: var(--font-body);
        font-size: 15px;
        color: var(--color-grey);
        margin-bottom: 16px;
      ">
        Masih ada pertanyaan lain?
      </p>
      <Button href="/faq" variant="secondary" size="sm">
        Lihat Semua FAQ →
      </Button>
    </div>
  </div>
</section>

<script>
  import { initFaqToggle } from '../../../lib/faq-toggle';
  document.addEventListener('DOMContentLoaded', initFaqToggle);
</script>
