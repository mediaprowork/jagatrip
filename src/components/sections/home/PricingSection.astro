---
import { getEntry } from 'astro:content';
import { waLink } from '../../../data/site';

const trip = await getEntry('trips', 'malaysia-thailand');
const inclusions = trip!.data.inclusions;
const wa = waLink('Malaysia-Thailand', '24-28 Juni 2026');
---

<section id="pricing" class="py-24 bg-jaga-bg border-t border-gray-200">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 max-w-4xl mx-auto">
      <h2 class="text-4xl md:text-6xl font-black text-gray-900 mb-6 tracking-tight">Investasi Terbaik yang Pernah Kamu Buat untuk Sekolah dan Instansimu</h2>
    </div>

    <div class="grid lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-7 bg-white p-8 md:p-12 rounded-[2.5rem] shadow-xl border border-gray-100">
        <p class="text-2xl text-gray-900 font-black mb-8 uppercase tracking-wide border-b border-gray-100 pb-4">PERJALANAN EDUKASI SUDAH TERMASUK:</p>

        <div class="grid sm:grid-cols-2 gap-4">
          {inclusions.map((item, i) => (
            <div class={`flex items-start bg-jaga-bg p-4 rounded-xl border border-gray-100${i === inclusions.length - 1 ? ' sm:col-span-2' : ''}`}>
              <span class="text-2xl mr-3 flex-shrink-0">{item.icon}</span>
              <div>
                <p class="text-gray-900 font-bold leading-tight">{item.label}</p>
                <p class="text-gray-600 text-sm mt-1">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 p-6 bg-orange-50 rounded-2xl border border-orange-200">
          <p class="text-base text-gray-800 leading-relaxed"><span class="font-bold text-jaga-orange uppercase mr-2">CATATAN PENTING:</span> Meeting Point keberangkatan: KLIA (Kuala Lumpur International Airport). Tiket pesawat dari kota asal peserta menuju KLIA ditanggung dalam paket.</p>
        </div>
      </div>

      <div class="lg:col-span-5 space-y-6">
        <div class="bg-gradient-to-br from-jaga-orange to-orange-500 p-10 md:p-12 rounded-[2.5rem] shadow-[0_20px_50px_rgba(255,107,53,0.3)] text-white transform hover:-translate-y-2 transition-transform duration-300 relative overflow-hidden border-4 border-white/20">
          <div class="absolute top-0 right-0 bg-white text-jaga-orange font-black py-2 px-6 rounded-bl-2xl text-sm tracking-wider uppercase shadow-md">TERBATAS</div>
          <h3 class="text-3xl font-black mb-2">🔥 EARLY BIRD</h3>
          <p class="mb-8 text-orange-100 font-semibold text-lg border-b border-white/20 pb-4 inline-block">Sampai 10 Juni 2026</p>

          <div class="text-5xl md:text-6xl font-black mb-2 tracking-tight">Rp 7.9Jt <span class="text-xl md:text-2xl font-bold text-orange-100">/ org</span></div>

          <p class="text-lg md:text-xl font-bold mb-4 opacity-90">(Rp 7.900.000)</p>
          <p class="text-base mb-10 text-orange-100 font-medium">All-in (sudah termasuk semua fasilitas)</p>
          <a href={wa} target="_blank" class="block w-full text-center bg-white text-jaga-orange font-black text-xl py-5 rounded-full shadow-xl hover:bg-gray-50 hover:scale-[1.02] transition-all">DAFTAR SEKARANG</a>
        </div>

        <div class="bg-white p-10 rounded-[2.5rem] shadow-lg border border-gray-200 flex justify-between items-center">
          <div>
            <h3 class="text-2xl font-bold text-gray-900 mb-1">HARGA NORMAL</h3>
            <p class="text-gray-500 font-medium">Berlaku setelah 10 Juni 2026</p>
          </div>
          <div class="text-right">
            <div class="text-3xl font-black text-gray-900">Rp 8.25Jt</div>
            <div class="text-sm font-bold text-gray-500">(Rp 8.250.000) / orang</div>
          </div>
        </div>

        <p class="text-center text-sm md:text-base text-gray-500 font-medium leading-relaxed px-4">
          Kuota TERBATAS — Hanya untuk Peserta Serius yang Siap Level Up! Early Bird berakhir 10 Juni 2026. Harga normal setelahnya.
        </p>
      </div>
    </div>
  </div>
</section>
