---
import { waLink } from '../../../data/site';
const wa = waLink('Malaysia-Thailand', '24-28 Juni 2026');
---

<section id="pricing" class="py-24 bg-jaga-bg border-t border-gray-200">
  <div class="max-w-3xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tight">
        Investasi Terbaik yang Pernah Kamu Buat untuk Sekolah dan Instansimu
      </h2>
    </div>

    <div class="space-y-6">
      <!-- Early Bird -->
      <div class="bg-linear-to-br from-jaga-orange to-orange-500 p-10 md:p-12 rounded-4xl shadow-[0_20px_50px_rgba(255,107,53,0.3)] text-white relative overflow-hidden border-4 border-white/20">
        <div class="absolute top-0 right-0 bg-white text-jaga-orange font-black py-2 px-6 rounded-bl-2xl text-sm tracking-wider uppercase shadow-md">TERBATAS</div>
        <p class="text-base text-orange-100 font-medium mb-1">Harga Mulai dari</p>
        <div class="text-5xl md:text-6xl font-black mb-2 tracking-tight">
          Rp 6.600.000 <span class="text-xl md:text-2xl font-bold text-orange-100">/ orang</span>
        </div>
        <p class="text-base mb-10 text-orange-100 font-medium">All-in · Harga bervariasi sesuai kota keberangkatan</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={wa} target="_blank" rel="noopener noreferrer" class="flex-1 text-center bg-white text-jaga-orange font-black text-lg py-4 rounded-full shadow-xl hover:bg-gray-50 hover:scale-[1.02] transition-all">
            DAFTAR SEKARANG
          </a>
          <a href="/harga" class="flex-1 text-center border-2 border-white text-white hover:bg-white hover:text-jaga-orange font-black text-lg py-4 rounded-full transition-all">
            Lihat Paket Harga
          </a>
        </div>
      </div>

      <p class="text-center text-lg md:text-xl text-gray-700 font-bold leading-relaxed px-4">
        Kuota TERBATAS — Hanya untuk Peserta Serius yang Siap Level Up!<br/>
        Early Bird berakhir 10 Juni 2026. Harga bervariasi sesuai kota keberangkatan.
      </p>
    </div>
  </div>
</section>
