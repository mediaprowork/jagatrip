---
import { getCollection } from 'astro:content';

const allTrips = await getCollection('trips');
const trips = allTrips.sort((a, b) => a.data.monthNum - b.data.monthNum);
---

<section
  id="agenda"
  class="section agenda-section"
  aria-labelledby="agenda-title"
>
  <div class="container">
    <!-- Header -->
    <div class="agenda-header reveal">
      <span class="eyebrow">AGENDA 2026</span>
      <h2 id="agenda-title" class="section-title">
        7 Destinasi, <span class="italic">7 Pengalaman Tak Terlupakan.</span>
      </h2>
      <p class="agenda-sub">
        Klik destinasi untuk lihat program lengkap, itinerary, dan harga.
      </p>
    </div>

    <!-- Trip cards grid -->
    <div class="trips-grid">
      {trips.map((trip, i) => (
        <a
          href={`/trips/${trip.data.slug}`}
          class="dest-card-premium reveal"
          style={`background: var(${trip.data.gradient});`}
          aria-label={`${trip.data.destination} — ${trip.data.month} ${trip.data.year}`}
        >
          {/* Overlay gradient bottom */}
          {/* Texture overlay left */}

          {/* TOP: flag + badge */}
          <div class="card-top">
            <span class="card-flag" aria-hidden="true">{trip.data.flag}</span>
            <span class="card-badge">
              {trip.data.category}
            </span>
          </div>

          {/* BOTTOM: destination info */}
          <div class="card-bottom">
            <h3 class="card-destination">{trip.data.destination}</h3>
            <p class="card-duration">{trip.data.duration}</p>
            <p class="card-month">{trip.data.month} {trip.data.year}</p>
            <span class="card-cta">Lihat Detail →</span>
          </div>

          {/* Number watermark */}
          <span class="card-watermark" aria-hidden="true">
            {String(i + 1).padStart(2, '0')}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .agenda-section {
    background: var(--color-paper);
  }

  .agenda-header {
    text-align: center;
    max-width: 720px;
    margin-inline: auto;
    margin-bottom: 64px;
  }

  .agenda-sub {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-grey);
    margin-top: 16px;
  }

  /* Grid */
  .trips-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* Premium card */
  .dest-card-premium {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 280px;
    border-radius: 24px;
    overflow: hidden;
    position: relative;
    padding: 24px;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Bottom dark overlay */
  .dest-card-premium::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(0, 0, 0, 0.18) 50%,
      transparent 100%
    );
    z-index: 1;
    border-radius: inherit;
  }

  /* Left white texture wash */
  .dest-card-premium::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.06) 0%,
      transparent 50%
    );
    z-index: 2;
    border-radius: inherit;
    pointer-events: none;
  }

  .dest-card-premium:hover {
    transform: translateY(-8px);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
  }

  /* TOP section */
  .card-top {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .card-flag {
    font-size: 48px;
    line-height: 1;
    display: block;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.3));
  }

  .card-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.6);
    padding: 4px 12px;
    border-radius: 100px;
    white-space: nowrap;
    backdrop-filter: blur(4px);
    background: rgba(255, 255, 255, 0.1);
    margin-top: 6px;
  }

  /* BOTTOM section */
  .card-bottom {
    position: relative;
    z-index: 3;
  }

  .card-destination {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 800;
    color: white;
    line-height: 1.1;
    margin-bottom: 6px;
    letter-spacing: -0.5px;
  }

  .card-duration {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 2px;
  }

  .card-month {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 18px;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    color: white;
    background: rgba(255, 255, 255, 0.18);
    padding: 8px 18px;
    border-radius: 100px;
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    transition: background 0.2s ease;
  }

  .dest-card-premium:hover .card-cta {
    background: rgba(255, 255, 255, 0.28);
  }

  /* Number watermark */
  .card-watermark {
    position: absolute;
    bottom: 16px;
    right: 20px;
    z-index: 2;
    font-family: var(--font-display);
    font-size: 80px;
    font-weight: 900;
    font-style: italic;
    color: rgba(255, 255, 255, 0.12);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    letter-spacing: -2px;
  }

  /* Responsive */
  @media (max-width: 968px) {
    .trips-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .trips-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .dest-card-premium {
      min-height: 240px;
    }
  }
</style>
