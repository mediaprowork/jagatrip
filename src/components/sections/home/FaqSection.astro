---
import { getCollection } from 'astro:content';

const faqs = (await getCollection('faqs'))
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="faq" class="py-24 bg-white">
  <div class="max-w-3xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tight">
        FAQ (FREQUENTLY ASKED QUESTIONS)
      </h2>
      <p class="text-xl md:text-2xl text-gray-500 font-medium">
        Ada Pertanyaan? Kami Jawab Semuanya di Sini.
      </p>
    </div>

    <!-- Accordion -->
    <div class="divide-y divide-gray-200 border-y border-gray-200" id="faq-accordion">
      {faqs.map((faq, i) => (
        <div class="faq-item" data-index={i}>
          <button
            class="faq-trigger w-full flex items-center justify-between py-6 text-left gap-6 group"
            aria-expanded={i === 0 ? 'true' : 'false'}
            aria-controls={`faq-answer-${i}`}
            id={`faq-trigger-${i}`}
            type="button"
          >
            <span class="text-lg md:text-xl font-bold text-gray-900 leading-snug">
              {faq.data.question}
            </span>
            <span
              class={`faq-icon shrink-0 w-9 h-9 rounded-full flex items-center justify-center font-bold text-xl transition-all duration-300 ${
                i === 0
                  ? 'bg-jaga-orange text-white shadow-md'
                  : 'bg-orange-100 text-jaga-orange'
              }`}
              aria-hidden="true"
            >
              {i === 0 ? '×' : '+'}
            </span>
          </button>

          <div
            class="faq-answer overflow-hidden transition-all duration-300"
            id={`faq-answer-${i}`}
            role="region"
            aria-labelledby={`faq-trigger-${i}`}
            style={i === 0 ? 'max-height: 400px; padding-bottom: 24px;' : 'max-height: 0;'}
          >
            <p class="text-gray-600 text-base md:text-lg leading-relaxed">
              {faq.data.answer}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll<HTMLElement>('.faq-item');

  items.forEach((item) => {
    const btn    = item.querySelector<HTMLButtonElement>('.faq-trigger')!;
    const answer = item.querySelector<HTMLElement>('.faq-answer')!;
    const icon   = item.querySelector<HTMLElement>('.faq-icon')!;

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all
      items.forEach((other) => {
        const ob = other.querySelector<HTMLButtonElement>('.faq-trigger')!;
        const oa = other.querySelector<HTMLElement>('.faq-answer')!;
        const oi = other.querySelector<HTMLElement>('.faq-icon')!;
        ob.setAttribute('aria-expanded', 'false');
        oa.style.maxHeight = '0';
        oa.style.paddingBottom = '0';
        oi.textContent = '+';
        oi.classList.remove('bg-jaga-orange', 'text-white', 'shadow-md');
        oi.classList.add('bg-orange-100', 'text-jaga-orange');
      });

      // Open clicked if was closed
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        answer.style.paddingBottom = '24px';
        icon.textContent = '×';
        icon.classList.remove('bg-orange-100', 'text-jaga-orange');
        icon.classList.add('bg-jaga-orange', 'text-white', 'shadow-md');
      }
    });
  });
</script>
