---
import { SITE } from '../../../data/site';

const greeting = [
  'Halo admin JAGATRIP 👋',
  '',
  'Saya ingin mendaftar program *Early Bird* — JAGATRIP Malaysia-Thailand (24–28 Juni 2026).',
  '',
  '📋 Berikut data saya:',
  'Nama: ',
  'Asal Sekolah/Instansi: ',
  'Kota Keberangkatan: ',
  '',
  'Mohon informasi lebih lanjut mengenai ketersediaan slot Early Bird. Terima kasih! 🙏',
].join('\n');

const waLink = `https://wa.me/${SITE.waNumber}?text=${encodeURIComponent(greeting)}`;
---

<section class="py-16 md:py-24 bg-jaga-bg border-t border-gray-200 relative overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-jaga-orange rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-jaga-orange rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-4xl mx-auto px-6 relative z-10">

    <!-- Animated arrow pointing down -->
    <div class="flex justify-center mb-8">
      <div class="eb-bounce flex flex-col items-center text-jaga-orange">
        <p class="text-xs font-black uppercase tracking-[0.3em] mb-2">Penawaran Spesial</p>
        <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>

    <div class="bg-linear-to-br from-gray-900 via-gray-800 to-gray-900 rounded-4xl p-8 md:p-12 lg:p-16 text-white relative overflow-hidden shadow-[0_30px_80px_rgba(0,0,0,0.3)] border border-white/5">

      <!-- Decorative elements -->
      <div class="absolute top-0 right-0 w-72 h-72 bg-jaga-orange/15 rounded-full blur-[80px]"></div>
      <div class="absolute bottom-0 left-0 w-56 h-56 bg-jaga-orange/10 rounded-full blur-[60px]"></div>
      <div class="absolute top-0 left-0 w-full h-1 bg-linear-to-r from-transparent via-jaga-orange to-transparent"></div>

      <div class="relative z-10">
        <!-- Top: badge + heading -->
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 bg-jaga-orange/20 border border-jaga-orange/40 backdrop-blur-sm text-jaga-orange font-black text-xs md:text-sm uppercase tracking-[0.3em] px-6 py-2.5 rounded-full mb-6">
            <span class="eb-pulse inline-block w-2 h-2 bg-jaga-orange rounded-full"></span>
            Potongan Khusus · 10 Slot
          </div>

          <h2 class="text-3xl md:text-4xl lg:text-5xl font-black leading-tight mb-3 tracking-tight">
            Khusus <span class="text-jaga-orange">10 Pendaftar</span> Pertama
          </h2>
          <p class="text-gray-400 text-base md:text-lg max-w-xl mx-auto">
            Dapatkan harga spesial untuk kamu yang ambil keputusan cepat
          </p>
        </div>

        <!-- Pricing comparison -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 mb-10">
          <!-- Normal price -->
          <div class="text-center opacity-50">
            <p class="text-xs font-bold uppercase tracking-wider text-gray-500 mb-1">Harga Normal</p>
            <p class="text-3xl md:text-4xl font-black text-gray-500 line-through decoration-red-500 decoration-2">Rp 7.000.000</p>
          </div>

          <!-- Arrow -->
          <div class="hidden sm:block">
            <svg class="w-10 h-10 text-jaga-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </div>
          <div class="block sm:hidden">
            <svg class="w-8 h-8 text-jaga-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </div>

          <!-- Early Bird price -->
          <div class="text-center">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-jaga-orange mb-1">🔥 Early Bird</p>
            <p class="text-5xl md:text-6xl lg:text-7xl font-black text-white tracking-tight leading-none whitespace-nowrap">
              Rp&nbsp;6.500.000
            </p>
            <p class="text-gray-400 text-sm mt-2 font-medium">per orang · All-in</p>
          </div>
        </div>

        <!-- Savings badge -->
        <div class="flex justify-center mb-8">
          <div class="inline-flex items-center gap-2 bg-green-500/20 border border-green-400/30 text-green-400 text-sm md:text-base font-bold px-6 py-2 rounded-full">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Hemat Rp 500.000
          </div>
        </div>

        <!-- CTA -->
        <div class="flex flex-col items-center gap-4">
          <a
            href="#daftar"
            class="group inline-flex items-center gap-3 bg-jaga-orange hover:bg-jaga-orange-600 text-white font-black text-lg md:text-xl px-10 md:px-14 py-4 md:py-5 rounded-full shadow-[0_10px_40px_rgba(255,107,53,0.4)] hover:shadow-[0_15px_50px_rgba(255,107,53,0.5)] transition-all transform hover:-translate-y-1"
          >
            Amankan Slot Sekarang
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <p class="text-gray-500 text-xs">⚡ Kuota terbatas — slot bisa habis kapan saja</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .eb-bounce {
    animation: eb-bounce 2s ease-in-out infinite;
  }
  @keyframes eb-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }
  .eb-pulse {
    animation: eb-pulse 1.5s ease-in-out infinite;
  }
  @keyframes eb-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
</style>
