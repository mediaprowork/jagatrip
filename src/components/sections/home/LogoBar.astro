---
import { getCollection } from 'astro:content';

const partners = await getCollection('partners');
---

<div class="logobar" aria-label="Sekolah dan institusi mitra JAGATRIP">
  <div class="container">
    <div class="logobar-inner">

      <!-- Label -->
      <p class="logobar-label">Dipercaya oleh</p>

      <!-- Divider -->
      <div class="logobar-divider" aria-hidden="true"></div>

      <!-- Partner names -->
      <div class="logobar-partners" role="list">
        {partners.map((partner) => (
          <span class="logobar-item" role="listitem">
            {partner.data.name}
          </span>
        ))}
      </div>

      <!-- Trailing badge -->
      <div class="logobar-badge" aria-label="Dan masih banyak lagi">
        <span>+</span>
      </div>
    </div>
  </div>
</div>

<style>
  .logobar {
    background: var(--color-white);
    border-top: 1px solid var(--color-grey-light);
    border-bottom: 1px solid var(--color-grey-light);
    padding-block: 20px;
    overflow: hidden;
  }

  .logobar-inner {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .logobar-inner::-webkit-scrollbar { display: none; }

  .logobar-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-grey);
    white-space: nowrap;
    flex-shrink: 0;
    margin: 0;
  }

  .logobar-divider {
    width: 1px;
    height: 20px;
    background: var(--color-grey-light);
    flex-shrink: 0;
  }

  .logobar-partners {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }

  .logobar-item {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-ink);
    opacity: 0.45;
    white-space: nowrap;
    padding-inline: 20px;
    border-right: 1px solid var(--color-grey-light);
    transition: opacity 0.2s;
    cursor: default;
  }

  .logobar-item:first-child { padding-left: 0; }
  .logobar-item:last-child  { border-right: none; }

  .logobar-item:hover { opacity: 0.9; }

  .logobar-badge {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-orange-light);
    color: var(--color-orange);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    margin-left: auto;
  }

  @media (max-width: 768px) {
    .logobar-label {
      display: none;
    }
    .logobar-divider {
      display: none;
    }
    .logobar-inner {
      gap: 0;
    }
  }
</style>
