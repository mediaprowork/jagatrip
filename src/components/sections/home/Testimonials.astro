---
import { getCollection } from 'astro:content';

const testimonials = await getCollection('testimonials');
---

<section class="section testi-section" aria-labelledby="testimonials-title">
  <div class="container">

    <!-- Header row -->
    <div class="testi-header">
      <div>
        <span class="eyebrow">TESTIMONI</span>
        <h2 id="testimonials-title" class="section-title">
          Apa Kata Mereka yang<br />
          <span class="italic">Sudah Bergabung?</span>
        </h2>
      </div>
      <!-- Editorial accent -->
      <div class="testi-header-accent" aria-hidden="true">
        <p class="accent-num">★★★★★</p>
        <p class="accent-label">100%<br />satisfied</p>
      </div>
    </div>

    <!-- Editorial grid -->
    <div class="testi-grid">
      {testimonials.map((testi, i) => (
        <article
          class={`testi-card-new reveal ${i === 1 ? 'testi-featured' : ''}`}
          aria-label={`Testimoni dari ${testi.data.name}`}
          style={`transition-delay: ${i * 120}ms`}
        >
          <!-- Top: avatar + stars -->
          <div class="testi-top">
            <div
              class="testi-avatar"
              style={`background: var(${testi.data.avatarGradient ?? '--color-grad-avatar-1'});`}
              aria-hidden="true"
            >
              {testi.data.avatar}
            </div>
            <p class="testi-stars" aria-label={`${testi.data.rating} bintang`}>
              {'★'.repeat(testi.data.rating ?? 5)}
            </p>
          </div>

          <!-- Quote mark -->
          <p class="testi-openquote" aria-hidden="true">"</p>

          <!-- Quote text -->
          <blockquote class="testi-quote">
            {testi.data.quote}
          </blockquote>

          <!-- Author -->
          <div class="testi-author">
            <p class="testi-name">{testi.data.name}</p>
            <p class="testi-role">{testi.data.role}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .testi-section {
    background: var(--color-white);
  }

  /* Header */
  .testi-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 56px;
    gap: 24px;
  }

  .testi-header-accent {
    text-align: right;
    flex-shrink: 0;
  }

  .accent-num {
    font-size: 20px;
    color: #FBBF24;
    letter-spacing: 3px;
    margin: 0 0 4px;
  }

  .accent-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-grey);
    margin: 0;
    line-height: 1.5;
  }

  /* Grid */
  .testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  /* Card base */
  .testi-card-new {
    background: var(--color-paper);
    border-radius: 24px;
    padding: 32px 28px;
    border: 1px solid var(--color-grey-light);
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .testi-card-new:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 48px rgba(0,0,0,0.08);
    border-color: var(--color-orange-light);
  }

  /* Featured (middle) card */
  .testi-featured {
    background: var(--color-ink);
    border-color: transparent;
  }

  .testi-featured .testi-quote {
    color: rgba(255,255,255,0.88) !important;
  }

  .testi-featured .testi-name {
    color: white !important;
  }

  .testi-featured .testi-role {
    color: rgba(255,255,255,0.5) !important;
  }

  .testi-featured .testi-openquote {
    color: var(--color-orange) !important;
  }

  /* Card elements */
  .testi-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .testi-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
  }

  .testi-stars {
    font-size: 13px;
    color: #FBBF24;
    letter-spacing: 2px;
    margin: 0;
  }

  .testi-openquote {
    font-family: var(--font-display);
    font-size: 64px;
    font-weight: 900;
    color: var(--color-orange-light);
    line-height: 0.8;
    margin: 0 0 12px;
    display: block;
  }

  .testi-quote {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    font-style: italic;
    line-height: 1.65;
    color: var(--color-ink);
    margin: 0 0 auto;
    padding: 0;
    border: none;
    flex: 1;
  }

  .testi-author {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--color-grey-light);
  }

  .testi-featured .testi-author {
    border-top-color: rgba(255,255,255,0.1);
  }

  .testi-name {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0 0 3px;
  }

  .testi-role {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-grey);
    margin: 0;
  }

  @media (max-width: 968px) {
    .testi-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .testi-header-accent {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .testi-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
