---
import { getCollection } from 'astro:content';

const stats = await getCollection('stats');
---

<section
  class="stats-section"
  aria-label="Statistik JAGATRIP"
>
  <!-- Radial glow center -->
  <div class="stats-glow" aria-hidden="true"></div>

  <div class="container stats-container">
    <!-- Eyebrow -->
    <p class="stats-eyebrow">TRACK RECORD</p>

    <!-- Heading -->
    <h2 class="stats-heading">
      Angka yang <span class="stats-italic">Berbicara.</span>
    </h2>

    <!-- Stats row -->
    <div class="stats-row">
      {stats.map((stat, i) => (
        <>
          <div class="stat-block">
            <div
              class="stat-number"
              data-counter
              data-target={stat.data.target ?? 0}
              data-suffix={stat.data.suffix ?? ''}
              aria-label={`${stat.data.num} ${stat.data.label}`}
            >
              {stat.data.num}
            </div>
            <p class="stat-label-mono">{stat.data.label}</p>
          </div>
          {i < stats.length - 1 && (
            <div class="stat-divider" aria-hidden="true"></div>
          )}
        </>
      ))}
    </div>

    <!-- Footer line -->
    <p class="stats-footer">Sejak 2026 · Jakarta, Indonesia</p>
  </div>
</section>

<script>
  import { initStatCounter } from '../../../lib/stat-counter';
  document.addEventListener('DOMContentLoaded', initStatCounter);
</script>

<style>
  .stats-section {
    background: var(--color-ink);
    position: relative;
    overflow: hidden;
    padding-block: 96px;
  }

  @media (max-width: 768px) {
    .stats-section {
      padding-block: 64px;
    }
  }

  /* Radial glow */
  .stats-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(255, 255, 255, 0.05) 0%, transparent 65%);
    pointer-events: none;
  }

  .stats-container {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  /* Eyebrow */
  .stats-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-bottom: 20px;
    display: block;
  }

  /* Heading */
  .stats-heading {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -1px;
    color: white;
    margin-bottom: 64px;
  }

  .stats-italic {
    font-style: italic;
    color: var(--color-orange);
  }

  /* Stats row */
  .stats-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    margin-bottom: 48px;
  }

  /* Individual stat block */
  .stat-block {
    flex: 1;
    min-width: 160px;
    padding: 0 40px;
  }

  /* Big number */
  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(52px, 7vw, 72px);
    font-weight: 900;
    font-style: italic;
    line-height: 1;
    color: var(--color-orange);
    margin-bottom: 10px;
    display: block;
  }

  /* Label */
  .stat-label-mono {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.4;
  }

  /* Vertical divider */
  .stat-divider {
    width: 1px;
    height: 60px;
    background: rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
    align-self: center;
  }

  /* Footer */
  .stats-footer {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .stats-row {
      flex-wrap: wrap;
      gap: 40px;
    }

    .stat-block {
      flex: 0 0 calc(50% - 20px);
      min-width: 0;
      padding: 0 16px;
    }

    .stat-divider {
      display: none;
    }

    .stat-number {
      font-size: 52px;
    }
  }

  @media (max-width: 400px) {
    .stat-block {
      flex: 0 0 100%;
    }
  }
</style>
