---
interface TripFaqItem {
  q: string;
  a: string;
}

interface SharedFaqItem {
  id: string;
  question: string;
  answer: string;
  category: string;
}

interface Props {
  faqs: TripFaqItem[];
  sharedFaqs: SharedFaqItem[];
}

const { faqs, sharedFaqs } = Astro.props;

// Combine trip-specific + first 6 shared FAQs
const combinedFaqs = [
  ...faqs.map((f, i) => ({ id: `trip-faq-${i}`, question: f.q, answer: f.a })),
  ...sharedFaqs.slice(0, 6).map((f) => ({ id: f.id, question: f.question, answer: f.answer })),
];
---

<section
  class="section"
  style="background: var(--color-paper);"
  aria-labelledby="faq-heading"
>
  <div class="container">
    <div class="faq-header">
      <p class="eyebrow">FAQ</p>
      <h2 id="faq-heading" class="section-title">
        Ada Pertanyaan? Kami Jawab <span class="italic">Semuanya di Sini.</span>
      </h2>
      <p class="faq-sub">
        Ada pertanyaan lain? Hubungi kami langsung via WhatsApp — tim kami siap membantu 7 hari seminggu.
      </p>
    </div>

    <div class="faq-wrapper">
      {combinedFaqs.length > 0 ? (
        <div role="list" aria-label="Daftar pertanyaan yang sering ditanya">
          {combinedFaqs.map((faq, index) => (
            <div
              class="faq-item"
              role="listitem"
              id={`faq-item-${faq.id}`}
            >
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls={`faq-answer-${faq.id}`}
                id={`faq-btn-${faq.id}`}
              >
                <span>{faq.question}</span>
                <span class="faq-icon" aria-hidden="true">+</span>
              </button>
              <div
                class="faq-answer"
                id={`faq-answer-${faq.id}`}
                role="region"
                aria-labelledby={`faq-btn-${faq.id}`}
              >
                <p>{faq.answer}</p>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="faq-empty">
          Pertanyaan akan segera ditambahkan. Hubungi kami via WhatsApp untuk pertanyaan spesifik.
        </p>
      )}
    </div>
  </div>
</section>

<script>
  import { initFaqToggle } from '../../../lib/faq-toggle';
  document.addEventListener('DOMContentLoaded', initFaqToggle);
</script>

<style>
  .faq-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .faq-sub {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-grey);
    margin-top: 16px;
    max-width: 560px;
    margin-inline: auto;
  }

  .faq-wrapper {
    max-width: 800px;
    margin-inline: auto;
    background: var(--color-white);
    border-radius: var(--radius-card);
    padding: 8px 40px;
    border: 1px solid var(--color-grey-light);
  }

  .faq-empty {
    text-align: center;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-grey);
    padding: 32px;
  }

  @media (max-width: 640px) {
    .faq-wrapper {
      padding: 8px 20px;
    }
  }
</style>
