---
interface Props {
  destination: string;
}

const { destination } = Astro.props;

const reasons = [
  {
    num: '01',
    icon: '🎓',
    title: 'Sistem Pendidikan Kelas Dunia',
    desc: `Capek lihat sistem sekolah yang itu-itu aja? Di sini kamu akan menyaksikan langsung bagaimana sekolah-sekolah terbaik ${destination} membangun sistem pendidikan yang konsisten, inovatif, dan berdampak — dan kamu akan pulang membawa cetak birunya.`,
  },
  {
    num: '02',
    icon: '💡',
    title: 'Guru yang Benar-Benar Menginspirasi',
    desc: 'Bagaimana cara membuat guru semangat mengajar dan murid antusias belajar? Jawabannya ada di sekolah yang akan kamu kunjungi. Saksikan budaya belajar yang hidup dan rasakan sendiri perbedaannya.',
  },
  {
    num: '03',
    icon: '📱',
    title: 'Teknologi Pendidikan yang Relevan',
    desc: 'Pengen tahu gimana caranya bikin murid melek teknologi tanpa kehilangan esensi belajar? Program JAGATRIP akan membukakan matamu terhadap integrasi teknologi yang tepat guna di ruang kelas nyata.',
  },
  {
    num: '04',
    icon: '🤝',
    title: 'Jaringan yang Tidak Ternilai',
    desc: 'Bergabung dengan ratusan praktisi pendidikan terbaik dari Indonesia. Satu koneksi yang tepat bisa membuka puluhan peluang kolaborasi, kemitraan, dan pertumbuhan untuk sekolahmu.',
  },
  {
    num: '05',
    icon: '🏆',
    title: 'Rekognisi & Sertifikasi',
    desc: 'Peserta mendapatkan sertifikat resmi dari PT JAGATRIP MITRA EDUKASI sebagai bukti partisipasi dalam program benchmarking pendidikan internasional.',
  },
];
---

<section
  class="section"
  style="background: var(--color-white);"
  aria-labelledby="why-join-heading"
>
  <div class="container">
    <div class="why-header">
      <p class="eyebrow">KENAPA HARUS IKUT JAGATRIP?</p>
      <h2 id="why-join-heading" class="section-title">
        Karena Sekolahmu Layak Dapat <span class="italic">yang Terbaik</span>
      </h2>
      <p class="why-sub">
        Satu perjalanan bersama JAGATRIP bisa mengubah cara pandangmu terhadap pendidikan — selamanya.
      </p>
    </div>

    <ol class="reasons-list" aria-label={`5 alasan mengikuti JAGATRIP to ${destination}`}>
      {reasons.map((reason, i) => (
        <li class={`reason-card solution-card${i >= 3 ? ' reason-card-bottom' : ''}`}>
          <div class="reason-top">
            <span class="reason-num" aria-hidden="true">{reason.num}</span>
            <span class="reason-icon" aria-hidden="true">{reason.icon}</span>
          </div>
          <h3 class="reason-title">{reason.title}</h3>
          <p class="reason-desc">{reason.desc}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .why-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .why-sub {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    font-style: italic;
    color: var(--color-orange);
    margin-top: 16px;
    line-height: 1.5;
  }

  .reasons-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    /* 6-column grid: first 3 items span 2 cols each, last 2 span 3 cols each */
    grid-template-columns: repeat(6, 1fr);
    gap: 24px;
  }

  .reason-card {
    grid-column: span 2;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Items 4 and 5 each take 3 columns to fill row centered */
  .reason-card-bottom {
    grid-column: span 3;
  }

  .reason-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .reason-num {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 900;
    font-style: italic;
    color: var(--color-orange-light);
    line-height: 1;
  }

  .reason-icon {
    font-size: 28px;
    line-height: 1;
    margin-top: 4px;
  }

  .reason-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1.3;
    margin: 0;
  }

  .reason-desc {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-grey);
    margin: 0;
    flex: 1;
  }

  @media (max-width: 968px) {
    .reasons-list {
      grid-template-columns: repeat(2, 1fr);
    }

    .reason-card,
    .reason-card-bottom {
      grid-column: span 1;
    }
  }

  @media (max-width: 580px) {
    .reasons-list {
      grid-template-columns: 1fr;
    }
  }
</style>
