---
import { formatIDRShort, formatDate } from '../../../lib/format';
import { waLink, SITE } from '../../../data/site';

interface Props {
  earlyBird?: number;
  normal?: number;
  dpPercentage: number;
  earlyBirdDeadline?: Date;
  status: 'open' | 'limited' | 'soldout' | 'tba';
  destination: string;
  slug: string;
}

const { earlyBird, normal, dpPercentage, earlyBirdDeadline, status, destination, slug } = Astro.props;

const waHref = waLink(destination);
const waHrefFull = `https://wa.me/${SITE.waNumber}`;
const deadlineISO = earlyBirdDeadline ? earlyBirdDeadline.toISOString() : null;
const deadlineFormatted = earlyBirdDeadline ? formatDate(earlyBirdDeadline) : null;
const savings = earlyBird && normal ? normal - earlyBird : 0;

const showPricing = status === 'open' || status === 'limited';
---

<section
  class="section"
  style="background: var(--color-paper);"
  aria-labelledby="pricing-heading"
  id="harga"
>
  <div class="container">
    <div class="pricing-header">
      <p class="eyebrow">INVESTASI</p>
      <h2 id="pricing-heading" class="section-title">
        Investasi Terbaik yang Pernah Kamu Buat untuk <span class="italic">Sekolah dan Instansimu</span>
      </h2>
      <p class="pricing-sub">
        Kuota <strong>TERBATAS</strong> — Hanya untuk Peserta Serius yang Siap Level Up!
      </p>
    </div>

    {status === 'tba' && (
      <div class="pricing-tba">
        <div class="tba-icon" aria-hidden="true">🔜</div>
        <h3 class="tba-title">Harga Segera Diumumkan</h3>
        <p class="tba-desc">
          Harga akan segera diumumkan. Hubungi admin untuk info lebih lanjut dan daftarkan dirimu lebih awal sebelum kehabisan!
        </p>
        <a href={waHrefFull} class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
          Hubungi Admin WhatsApp <span aria-hidden="true">📱</span>
        </a>
      </div>
    )}

    {status === 'soldout' && (
      <div class="pricing-tba">
        <div class="tba-icon" aria-hidden="true">😢</div>
        <h3 class="tba-title">Kuota Penuh!</h3>
        <p class="tba-desc">
          Maaf, kursi untuk program ini sudah habis. Hubungi kami via WhatsApp untuk masuk waitlist atau informasi program berikutnya.
        </p>
        <a href={waHrefFull} class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
          Masuk Waitlist <span aria-hidden="true">📱</span>
        </a>
      </div>
    )}

    {showPricing && (
      <div class="pricing-cards-wrapper">
        <div class="pricing-cards">
          {/* Early Bird Card (featured) */}
          {earlyBird && (
            <div class="pricing-card featured" aria-label="Harga Early Bird">
              <div class="pricing-badge" aria-label="Label harga terbaik">
                <span aria-hidden="true">🔥</span> EARLY BIRD
              </div>

              <div class="pricing-card-inner">
                <h3 class="pricing-card-title">
                  <span aria-hidden="true">🔥</span> EARLY BIRD
                  {deadlineFormatted && <span class="deadline-text"> — Sampai {deadlineFormatted}</span>}
                </h3>

                <div class="price-display">
                  <span class="price-amount">{formatIDRShort(earlyBird)}</span>
                </div>
                <p class="price-per-orang">per orang</p>

                {savings > 0 && (
                  <div class="savings-badge">
                    Hemat {formatIDRShort(savings)} dari harga normal
                  </div>
                )}

                {deadlineISO && (
                  <div class="countdown-wrapper">
                    <p class="countdown-label-text">
                      <span aria-hidden="true">⏰</span> Berakhir: <time datetime={deadlineISO}>{deadlineFormatted}</time>
                    </p>
                    <div
                      data-countdown={deadlineISO}
                      aria-live="polite"
                      aria-label="Hitung mundur early bird"
                    ></div>
                  </div>
                )}

                <a href={waHref} class="btn btn-primary btn-lg pricing-btn" target="_blank" rel="noopener noreferrer">
                  Daftar Early Bird →
                </a>
              </div>
            </div>
          )}

          {/* Normal Price Card */}
          {normal && (
            <div class="pricing-card" aria-label="Harga Normal">
              <div class="pricing-card-inner">
                <h3 class="pricing-card-title">Harga Normal</h3>

                <div class="price-display">
                  <span
                    class="price-amount"
                    style={earlyBird ? 'text-decoration: line-through; color: var(--color-grey); font-size: 36px;' : ''}
                  >
                    {formatIDRShort(normal)}
                  </span>
                </div>
                <p class="price-per-orang">per orang | Berlaku setelah {deadlineFormatted ?? '10 Juni 2026'}</p>

                {earlyBird && (
                  <p class="normal-note">
                    Harga normal berlaku setelah batas early bird berakhir
                  </p>
                )}

                <a href={waHref} class="btn btn-secondary btn-lg pricing-btn" target="_blank" rel="noopener noreferrer">
                  Daftar Sekarang →
                </a>
              </div>
            </div>
          )}
        </div>

        <p class="dp-info">
          <span aria-hidden="true">💳</span>
          DP {dpPercentage}% untuk konfirmasi seat · Pelunasan H-7 sebelum keberangkatan
        </p>

        <div class="pricing-urgency">
          <p>JANGAN TUNDA LAGI! Kursi Terbatas — Daftar Sekarang Sebelum Penuh</p>
        </div>

        <div class="pricing-wa-cta">
          <a
            href={`https://wa.me/${SITE.waNumber}`}
            class="btn btn-wa btn-lg"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Daftar via WhatsApp ${SITE.waDisplay}`}
          >
            DAFTAR SEKARANG via WhatsApp <span aria-hidden="true">📱</span> {SITE.waDisplay}
          </a>
        </div>
      </div>
    )}
  </div>
</section>

<script>
  import { initCountdown } from '../../../lib/countdown';
  document.addEventListener('DOMContentLoaded', initCountdown);
</script>

<style>
  .pricing-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .pricing-sub {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-grey);
    margin-top: 16px;
  }

  .pricing-sub strong {
    color: var(--color-orange);
  }

  .pricing-urgency {
    background: var(--color-orange);
    border-radius: 16px;
    padding: 16px 24px;
    text-align: center;
    margin-top: 32px;
  }

  .pricing-urgency p {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 800;
    color: white;
    margin: 0;
    line-height: 1.4;
  }

  /* TBA / Soldout state */
  .pricing-tba {
    max-width: 560px;
    margin-inline: auto;
    text-align: center;
    background: var(--color-white);
    border-radius: var(--radius-card);
    padding: 48px 40px;
    border: 2px solid var(--color-grey-light);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .tba-icon {
    font-size: 48px;
    line-height: 1;
  }

  .tba-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 800;
    color: var(--color-ink);
  }

  .tba-desc {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-grey);
    margin: 0;
  }

  /* Pricing cards */
  .pricing-cards-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .pricing-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    width: 100%;
    max-width: 820px;
    margin-inline: auto;
  }

  .pricing-card-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pricing-card-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0;
    margin-top: 8px;
  }

  .price-display {
    margin-top: 8px;
  }

  .price-per-orang {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-grey);
    margin: 0;
    margin-top: -8px;
  }

  .savings-badge {
    background: var(--color-orange-light);
    color: var(--color-orange-dark);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 8px 14px;
    border-radius: 100px;
    display: inline-block;
    text-align: center;
  }

  .countdown-wrapper {
    background: var(--color-paper);
    border-radius: var(--radius-input);
    padding: 16px;
  }

  .countdown-label-text {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-grey);
    margin: 0 0 12px 0;
  }

  .normal-note {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-grey);
    margin: 0;
    font-style: italic;
  }

  .pricing-btn {
    width: 100%;
    justify-content: center;
    margin-top: auto;
  }

  .dp-info {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-grey);
    text-align: center;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pricing-wa-cta {
    text-align: center;
  }

  @media (max-width: 640px) {
    .pricing-cards {
      grid-template-columns: 1fr;
    }

    .pricing-tba {
      padding: 32px 24px;
    }
  }
</style>
