---
import { waLink } from '../../../data/site';

interface Props {
  destination: string;
  dateRange: string;
}

const { destination, dateRange } = Astro.props;
const waHref = waLink(destination);

const problems = [
  'Sekolahmu sudah bagus — tapi kamu ngerasa ada yang kurang, dan nggak tau harus mulai dari mana.',
  'Kamu pengen sistem pendidikan yang lebih modern, tapi referensinya terbatas dan tidak bisa keluar dari "zona nyaman" yang itu-itu aja.',
  'Sudah banyak seminar dan pelatihan, tapi hasilnya belum mengubah kualitas sekolahmu secara nyata.',
  'Kamu ingin tahu bagaimana sekolah-sekolah terbaik dunia membangun budaya belajar yang kuat — tapi akses ke mereka terasa sangat jauh.',
  'Siswa dan guru butuh inspirasi baru — tapi kamu sendiri bingung harus mencari inspirasi itu ke mana.',
  'Ingin mengadopsi praktik terbaik dari sekolah internasional, tapi tidak punya networking yang tepat untuk memulainya.',
];
---

<section
  class="section"
  style="background: var(--color-white);"
  aria-labelledby="problem-hook-heading"
>
  <div class="container">
    <div class="problem-header">
      <p class="eyebrow">APAKAH KAMU MENGALAMI INI?</p>
      <h2 id="problem-hook-heading" class="section-title">
        Apakah Kamu <span class="italic">Mengalami Ini?</span>
      </h2>
    </div>

    <ul class="problem-list" aria-label="Daftar masalah yang mungkin kamu alami">
      {problems.map((problem) => (
        <li class="problem-item">
          <div class="problem-check" aria-hidden="true">✓</div>
          <p class="problem-text">{problem}</p>
        </li>
      ))}
    </ul>

    <div class="problem-closing">
      <p class="closing-headline">
        Kalau jawabanmu <strong>"IYA"</strong> maka kamu perlu ikut event ini
      </p>
      <p class="closing-trip">JAGATRIP TO {destination.toUpperCase()}</p>
      <p class="closing-date">{dateRange}</p>
      <a href={waHref} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
        Daftar Sekarang →
      </a>
    </div>

    <p class="problem-tagline">
      Karena ilmu yang paling mahal bukan yang ada di buku teks — melainkan yang tersimpan di balik tembok sekolah-sekolah terbaik yang jarang dibuka untuk umum.
    </p>
  </div>
</section>

<style>
  .problem-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .problem-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 48px;
  }

  .problem-text {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-ink);
    margin: 0;
  }

  .problem-closing {
    background: var(--color-orange-light);
    border-radius: 20px;
    padding: 32px;
    margin-top: 40px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .closing-headline {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.5;
    color: var(--color-ink);
    margin: 0;
  }

  .closing-headline strong {
    color: var(--color-orange);
  }

  .closing-trip {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 900;
    color: var(--color-ink);
    margin: 0;
  }

  .closing-date {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--color-grey);
    margin: 0;
  }

  .problem-tagline {
    margin-top: 32px;
    text-align: center;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    font-style: italic;
    color: var(--color-grey);
    max-width: 680px;
    margin-inline: auto;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .problem-list {
      grid-template-columns: 1fr;
    }

    .problem-closing {
      padding: 24px;
    }
  }
</style>
