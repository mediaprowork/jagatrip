---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav        from '../components/layout/Nav.astro';
import Footer     from '../components/layout/Footer.astro';
import FloatingWA from '../components/layout/FloatingWA.astro';
import { SITE, waLink } from '../data/site';
import { breadcrumbSchema } from '../data/schemas/breadcrumb';

const wa = waLink();

const extraSchemas = [
  breadcrumbSchema([{ name: 'Kontak', url: `${SITE.url}/kontak` }]),
];

const channels = [
  {
    icon: '💬',
    title: 'WhatsApp',
    desc: 'Respon tercepat. Chat kami langsung untuk konsultasi program.',
    value: SITE.waDisplay,
    href: wa,
    cta: 'Chat Sekarang',
  },
  {
    icon: '✉️',
    title: 'Email',
    desc: 'Untuk pertanyaan formal atau kerjasama institusi.',
    value: SITE.email,
    href: `mailto:${SITE.email}`,
    cta: 'Kirim Email',
  },
  {
    icon: '📍',
    title: 'Lokasi',
    desc: 'Berbasis di Jakarta, melayani seluruh Indonesia.',
    value: SITE.location,
    href: undefined,
    cta: undefined,
  },
];
---

<BaseLayout
  title="Kontak JAGATRIP — Hubungi Admin via WhatsApp"
  description="Hubungi JAGATRIP via WhatsApp 085643972139 atau email admin@jagatrip.com. Konsultasi gratis program edu-tourism 2026."
  extraSchemas={extraSchemas}
>
  <Nav />

  <main id="main">

    <!-- HERO -->
    <section class="relative pt-32 pb-16 lg:pt-40 lg:pb-20 overflow-hidden bg-jaga-bg">
      <div class="absolute inset-0 z-0 opacity-10 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-jaga-orange via-transparent to-transparent"></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
        <span class="inline-block py-2 px-5 rounded-full bg-jaga-orange/10 text-jaga-orange font-bold text-sm md:text-base mb-6 tracking-widest uppercase shadow-sm">
          Hubungi Kami
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-gray-900 tracking-tight leading-[1.1] mb-6">
          Ada yang Ingin <span class="text-transparent bg-clip-text bg-gradient-to-r from-jaga-orange to-orange-400">Ditanyakan?</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed">
          Tim kami siap membantu. Pilih channel yang paling nyaman untukmu.
        </p>
      </div>
    </section>

    <!-- Contact channels -->
    <section class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-6">
          {channels.map((c) => (
            <div class="bg-jaga-bg p-10 rounded-[2rem] shadow-sm border border-gray-100 text-center flex flex-col">
              <div class="text-5xl mb-4" aria-hidden="true">{c.icon}</div>
              <h2 class="text-2xl font-bold text-gray-900 mb-3">{c.title}</h2>
              <p class="text-gray-600 leading-relaxed mb-4 flex-1">{c.desc}</p>
              <p class="font-bold text-gray-900 mb-6 break-all">{c.value}</p>
              {c.href && c.cta && (
                <a
                  href={c.href}
                  target={c.href.startsWith('http') ? '_blank' : undefined}
                  rel={c.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  class="inline-block bg-jaga-orange hover:bg-jaga-orange-600 text-white px-6 py-3 rounded-full font-bold text-sm shadow-md hover:shadow-lg transition-all transform hover:-translate-y-1"
                >
                  {c.cta}
                </a>
              )}
            </div>
          ))}
        </div>

        <!-- Big WA CTA -->
        <div class="mt-16 max-w-3xl mx-auto bg-gray-900 rounded-[2rem] p-12 text-center text-white">
          <div class="text-5xl mb-4" aria-hidden="true">💬</div>
          <h2 class="text-3xl md:text-4xl font-black mb-4">Konsultasi Gratis via WhatsApp</h2>
          <p class="text-gray-300 leading-relaxed mb-8 text-lg">
            Tanyakan apa saja — program mana yang cocok, harga, itinerary, atau cara daftar.
            Tim kami akan merespons dalam 1×24 jam.
          </p>
          <a
            href={wa}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-jaga-orange hover:bg-jaga-orange-600 text-white px-10 py-4 rounded-full font-bold text-lg shadow-xl hover:shadow-2xl transition-all transform hover:-translate-y-1"
          >
            💬 Chat {SITE.waDisplay}
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingWA />
</BaseLayout>
