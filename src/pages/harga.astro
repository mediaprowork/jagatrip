---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import FloatingWA from '../components/layout/FloatingWA.astro';
import { SITE, waLink } from '../data/site';
import { breadcrumbSchema } from '../data/schemas/breadcrumb';

const wa = waLink('Malaysia-Thailand', '24-28 Juni 2026');
const waConsult = waLink('Konsultasi Harga');

const extraSchemas = [
  breadcrumbSchema([{ name: 'Daftar Harga', url: `${SITE.url}/harga` }]),
];

// ── Pricing data from Google Sheets (HARGA JUAL FIX TRIP JUNI) ───────────────
// 40 Peserta + 5 Panitia | Provinsi ≤ Rp300rb selisih → disamakan ke tertinggi
// Meeting point: KLIA (Kuala Lumpur International Airport)

type PriceTier = {
  no: number;
  cities: string[];
  price: string;
  priceNum: number;
  region: string;
  icon: string;
};

const tiers: PriceTier[] = [
  { no: 1,  cities: ['Padang', 'Pekanbaru'],                                                          price: 'Rp 6.600.000',  priceNum: 6600000,  region: 'Sumatera',      icon: '🌴' },
  { no: 2,  cities: ['Aceh (BTJ)', 'Batam', 'Medan', 'Palembang (PLM)'],                             price: 'Rp 7.500.000',  priceNum: 7500000,  region: 'Sumatera',      icon: '🌴' },
  { no: 3,  cities: ['Jakarta', 'Pontianak'],                                                         price: 'Rp 7.900.000',  priceNum: 7900000,  region: 'Jawa / Kalimantan', icon: '🏙️' },
  { no: 4,  cities: ['Bali (Denpasar)', 'Balikpapan (BPN)', 'Semarang (SRG)', 'Surabaya'],           price: 'Rp 8.600.000',  priceNum: 8600000,  region: 'Jawa / Bali',   icon: '🏖️' },
  { no: 5,  cities: ['Jogja (YIA)', 'Makassar (UPG)'],                                               price: 'Rp 8.800.000',  priceNum: 8800000,  region: 'Jawa / Sulawesi', icon: '🏯' },
  { no: 6,  cities: ['Lampung (TKG)'],                                                               price: 'Rp 10.200.000', priceNum: 10200000, region: 'Sumatera',      icon: '🌴' },
  { no: 7,  cities: ['Pangkal Pinang (PGK)', 'Tarakan (TRK)'],                                       price: 'Rp 11.500.000', priceNum: 11500000, region: 'Kalimantan',    icon: '🌿' },
  { no: 8,  cities: ['Lombok (LOP)'],                                                                price: 'Rp 11.800.000', priceNum: 11800000, region: 'Nusa Tenggara', icon: '🏝️' },
  { no: 9,  cities: ['Banjarmasin (BDJ)', 'Bengkulu (BKS)'],                                         price: 'Rp 12.500.000', priceNum: 12500000, region: 'Kalimantan / Sumatera', icon: '🌿' },
  { no: 10, cities: ['NTT (Kupang / KOE)'],                                                          price: 'Rp 13.000.000', priceNum: 13000000, region: 'Nusa Tenggara', icon: '🏝️' },
  { no: 11, cities: ['Palu (PLW)'],                                                                  price: 'Rp 13.900.000', priceNum: 13900000, region: 'Sulawesi',      icon: '⚓' },
  { no: 12, cities: ['Maluku / Ambon (AMQ)', 'Palangkaraya (PKY)'],                                  price: 'Rp 15.200.000', priceNum: 15200000, region: 'Maluku / Kalimantan', icon: '🦜' },
  { no: 13, cities: ['Gorontalo (GTO)', 'Sorong (SOQ)'],                                             price: 'Rp 16.800.000', priceNum: 16800000, region: 'Sulawesi / Papua', icon: '🦜' },
  { no: 14, cities: ['Kendari (KDI)'],                                                               price: 'Rp 18.900.000', priceNum: 18900000, region: 'Sulawesi',      icon: '⚓' },
  { no: 15, cities: ['Jayapura (DJJ)'],                                                              price: 'Rp 20.700.000', priceNum: 20700000, region: 'Papua',         icon: '🦅' },
];

const tabs = [
  { id: 'trip-juni',   label: 'Harga Jual Juni 2026' },
  { id: 'per-kota',    label: 'Per Kota' },
  { id: 'detail-tiket', label: 'Detail Tiket' },
];
---

<BaseLayout
  title="Daftar Harga JAGATRIP — Malaysia-Thailand Juni 2026"
  description="Daftar harga lengkap program JAGATRIP Malaysia-Thailand 24-28 Juni 2026 per kota keberangkatan. Harga mulai Rp6.600.000/orang all-in."
  extraSchemas={extraSchemas}
>
  <Nav />

  <main id="main">

    <!-- HERO -->
    <section class="relative pt-32 pb-16 lg:pt-40 lg:pb-20 overflow-hidden bg-jaga-bg">
      <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
        <span class="inline-block py-2 px-5 rounded-full bg-jaga-orange/10 text-jaga-orange font-bold text-sm mb-6 tracking-widest uppercase shadow-sm">
          Malaysia & Thailand · 24–28 Juni 2026
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-gray-900 tracking-tight leading-tight mb-6">
          Daftar Harga Program
        </h1>
        <p class="text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto mb-8">
          Harga bervariasi sesuai kota keberangkatan. Semua paket <strong class="text-gray-900">All-in</strong> —
          tiket pesawat PP sudah termasuk.
        </p>
        <div class="inline-flex flex-wrap gap-3 justify-center">
          <div class="bg-white border border-gray-200 rounded-full px-5 py-2 text-sm font-semibold text-gray-700 shadow-sm">
            📅 Early Bird s/d 10 Juni 2026
          </div>
          <div class="bg-white border border-gray-200 rounded-full px-5 py-2 text-sm font-semibold text-gray-700 shadow-sm">
            ✈️ 15 Kota Keberangkatan
          </div>
          <div class="bg-jaga-orange text-white rounded-full px-5 py-2 text-sm font-bold shadow-sm">
            🔥 Mulai Rp 6.600.000
          </div>
        </div>
      </div>
    </section>

    <!-- PRICING TABLE SECTION -->
    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-5xl mx-auto px-6">

        <!-- Tab nav -->
        <div class="flex flex-wrap gap-2 mb-10 border-b border-gray-200">
          {tabs.map((tab, i) => (
            <button
              type="button"
              data-tab={tab.id}
              class={`tab-btn px-6 py-3 font-bold text-sm rounded-t-xl border border-b-0 transition-colors ${i === 0 ? 'bg-jaga-orange text-white border-jaga-orange' : 'bg-white text-gray-600 border-gray-200 hover:text-jaga-orange'}`}
            >
              {tab.label}
            </button>
          ))}
        </div>

        <!-- ── Tab 1: Harga Jual Juni ─────────────────────────────────────── -->
        <div id="panel-trip-juni" class="tab-panel">
          <p class="text-gray-500 text-sm leading-relaxed bg-orange-50 border border-orange-200 rounded-xl px-5 py-3 mb-6">
            <strong class="text-jaga-orange">CATATAN:</strong> Kapasitas 40 peserta + 5 panitia.
            Harga dalam satu tier yang selisihnya ≤ Rp300.000 disamakan ke harga tertinggi.
            Meeting point: KLIA (Kuala Lumpur International Airport).
          </p>
          <div class="overflow-hidden rounded-3xl border border-gray-200 shadow-sm">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-gray-900 text-white">
                  <th class="py-4 px-5 font-bold text-sm uppercase tracking-wider w-10">#</th>
                  <th class="py-4 px-5 font-bold text-sm uppercase tracking-wider">Provinsi / Kota Keberangkatan</th>
                  <th class="py-4 px-5 font-bold text-sm uppercase tracking-wider text-right whitespace-nowrap">Harga / Peserta</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {tiers.map((row) => (
                  <tr class="hover:bg-orange-50/50 transition-colors">
                    <td class="py-4 px-5 text-gray-400 font-medium text-sm">{row.no}</td>
                    <td class="py-4 px-5">
                      <div class="flex flex-wrap gap-2">
                        {row.cities.map(city => (
                          <span class="inline-block bg-jaga-bg border border-gray-100 text-gray-700 text-sm font-medium px-3 py-1 rounded-full">
                            {city}
                          </span>
                        ))}
                      </div>
                    </td>
                    <td class="py-4 px-5 text-right">
                      <span class="text-lg font-black text-jaga-orange">{row.price}</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- ── Tab 2: Per Kota ────────────────────────────────────────────── -->
        <div id="panel-per-kota" class="tab-panel hidden">
          <p class="text-gray-500 text-sm leading-relaxed bg-orange-50 border border-orange-200 rounded-xl px-5 py-3 mb-6">
            <strong class="text-jaga-orange">CATATAN:</strong> Tampilan per kota individual.
            Harga sudah all-in termasuk tiket pesawat PP dari kota asal ke KLIA.
          </p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {tiers.map((row) => (
              row.cities.map(city => (
                <div class="bg-jaga-bg border border-gray-100 rounded-2xl p-5 flex items-center justify-between hover:shadow-md transition-shadow group">
                  <div>
                    <p class="font-bold text-gray-900 text-sm">{city}</p>
                    <p class="text-xs text-gray-400 mt-0.5">All-in · Termasuk pesawat PP</p>
                  </div>
                  <p class="font-black text-jaga-orange text-base ml-4 shrink-0 group-hover:scale-105 transition-transform">{row.price}</p>
                </div>
              ))
            ))}
          </div>
        </div>

        <!-- ── Tab 3: Detail Tiket ─────────────────────────────────────────── -->
        <div id="panel-detail-tiket" class="tab-panel hidden">

          <!-- Route diagram -->
          <div class="bg-gray-900 text-white rounded-2xl px-6 py-5 mb-6 flex flex-col sm:flex-row items-center justify-center gap-3 text-center">
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wider mb-0.5">Kota Asal</p>
              <p class="font-black text-white text-lg">Kotamu</p>
            </div>
            <div class="text-jaga-orange text-2xl font-black hidden sm:block">→</div>
            <div class="text-jaga-orange text-xl font-black block sm:hidden">↓</div>
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wider mb-0.5">Meeting Point</p>
              <p class="font-black text-white text-lg">KLIA 🇲🇾</p>
              <p class="text-xs text-gray-400">Kuala Lumpur Intl Airport</p>
            </div>
            <div class="text-jaga-orange text-2xl font-black hidden sm:block">→</div>
            <div class="text-jaga-orange text-xl font-black block sm:hidden">↓</div>
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-wider mb-0.5">Destinasi</p>
              <p class="font-black text-white text-lg">Malaysia & Thailand 🇹🇭</p>
              <p class="text-xs text-gray-400">Ekspedisi 5 Hari 4 Malam</p>
            </div>
          </div>

          <!-- Search -->
          <div class="relative mb-8">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-lg">🔍</span>
            <input
              id="city-search"
              type="text"
              placeholder="Cari kota keberangkatanmu… contoh: Jakarta, Medan, Surabaya"
              class="w-full pl-12 pr-5 py-4 rounded-2xl border-2 border-gray-200 focus:border-jaga-orange focus:outline-none text-gray-700 font-medium placeholder:text-gray-400 text-sm"
            />
          </div>

          <!-- Tier cards -->
          <div id="tier-cards" class="space-y-4">
            {tiers.map((row) => (
              <div
                class="tier-card rounded-2xl border-2 border-gray-100 bg-white overflow-hidden hover:border-jaga-orange/40 hover:shadow-lg transition-all"
                data-cities={row.cities.join('|').toLowerCase()}
              >
                <div class="flex items-stretch">
                  <!-- Left: price block -->
                  <div class="bg-linear-to-br from-jaga-orange to-orange-500 text-white px-6 py-6 flex flex-col items-center justify-center min-w-[140px] shrink-0">
                    <p class="text-xs font-bold uppercase tracking-widest text-orange-100 mb-1">Tier {row.no}</p>
                    <p class="text-2xl md:text-3xl font-black leading-none">{row.price.replace('Rp ', 'Rp ')}</p>
                    <p class="text-xs text-orange-100 mt-1">per orang</p>
                    <p class="text-xs font-bold text-yellow-200 mt-2 bg-white/20 px-2 py-0.5 rounded-full">All-in ✓</p>
                  </div>

                  <!-- Right: city list + region -->
                  <div class="flex-1 px-6 py-5">
                    <div class="flex items-start justify-between gap-4 mb-3">
                      <div>
                        <p class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">
                          {row.icon} {row.region}
                        </p>
                        <p class="text-sm font-bold text-gray-600">
                          {row.cities.length === 1 ? '1 kota' : `${row.cities.length} kota`}
                        </p>
                      </div>
                      <a
                        href={`https://wa.me/${SITE.waNumber}?text=${encodeURIComponent(`Halo admin, saya mau tanya harga dari ${row.cities[0]} untuk JAGATRIP Malaysia-Thailand 24-28 Juni 2026. Mohon info lebih lanjut.`)}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="shrink-0 text-xs bg-jaga-orange/10 text-jaga-orange hover:bg-jaga-orange hover:text-white font-bold px-4 py-2 rounded-full transition-colors whitespace-nowrap"
                      >
                        💬 Daftar
                      </a>
                    </div>
                    <div class="flex flex-wrap gap-2">
                      {row.cities.map(city => (
                        <span class="city-tag inline-block bg-jaga-bg border border-gray-100 text-gray-700 text-sm font-medium px-3 py-1.5 rounded-full">
                          {city}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Empty state -->
          <div id="no-results" class="hidden text-center py-16">
            <p class="text-4xl mb-4">🔍</p>
            <p class="text-gray-500 font-medium">Kota tidak ditemukan. Coba nama lain atau hubungi admin.</p>
            <a href={waConsult} target="_blank" rel="noopener noreferrer"
               class="inline-block mt-4 bg-jaga-orange text-white font-bold px-6 py-3 rounded-full text-sm hover:bg-jaga-orange-600 transition-colors">
              Tanya Harga Kotamu →
            </a>
          </div>

          <!-- Note -->
          <p class="text-gray-400 text-xs text-center mt-8 leading-relaxed">
            Harga sudah termasuk tiket pesawat round-trip dari kota asal ke KLIA.<br/>
            Tier harga: provinsi dalam selisih ≤ Rp300.000 disamakan ke harga tertinggi.
          </p>
        </div>

        <!-- CTA -->
        <div class="mt-14 bg-gray-900 rounded-4xl p-10 md:p-12 text-center text-white">
          <h2 class="text-2xl md:text-3xl font-black mb-3">Mau Daftar atau Ada Pertanyaan?</h2>
          <p class="text-gray-300 mb-8 text-base leading-relaxed">
            Tim kami siap membantu. Chat langsung untuk konfirmasi kota keberangkatanmu dan amankan kursi sebelum penuh.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href={wa}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-jaga-orange hover:bg-jaga-orange-600 text-white font-bold text-lg px-10 py-4 rounded-full shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1 whitespace-nowrap"
            >
              💬 Daftar Sekarang
            </a>
            <a
              href={waConsult}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 border-2 border-white text-white hover:bg-white hover:text-gray-900 font-bold text-lg px-10 py-4 rounded-full transition-all whitespace-nowrap"
            >
              Tanya Harga Kotamu
            </a>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />
  <FloatingWA />
</BaseLayout>

<script>
  // ── Tab switching ──────────────────────────────────────────────────────────
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels  = document.querySelectorAll<HTMLDivElement>('.tab-panel');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      buttons.forEach(b => {
        b.classList.remove('bg-jaga-orange', 'text-white', 'border-jaga-orange');
        b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
      });
      btn.classList.add('bg-jaga-orange', 'text-white', 'border-jaga-orange');
      btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
      panels.forEach(p => p.classList.add('hidden'));
      document.getElementById(`panel-${target}`)?.classList.remove('hidden');
    });
  });

  // ── City search (Detail Tiket tab) ────────────────────────────────────────
  const searchInput = document.getElementById('city-search') as HTMLInputElement | null;
  const tierCards   = document.querySelectorAll<HTMLDivElement>('.tier-card');
  const noResults   = document.getElementById('no-results');

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();
    let found = 0;

    tierCards.forEach(card => {
      const cities = card.dataset.cities ?? '';
      const match  = !q || cities.includes(q);
      card.classList.toggle('hidden', !match);
      if (match) found++;

      // Highlight matching city tags
      card.querySelectorAll<HTMLElement>('.city-tag').forEach(tag => {
        const text = tag.textContent?.toLowerCase() ?? '';
        if (q && text.includes(q)) {
          tag.classList.add('bg-jaga-orange', 'text-white', 'border-jaga-orange');
          tag.classList.remove('bg-jaga-bg', 'text-gray-700', 'border-gray-100');
        } else {
          tag.classList.remove('bg-jaga-orange', 'text-white', 'border-jaga-orange');
          tag.classList.add('bg-jaga-bg', 'text-gray-700', 'border-gray-100');
        }
      });
    });

    noResults?.classList.toggle('hidden', found > 0);
  });
</script>
