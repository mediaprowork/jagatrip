---
import { getCollection } from 'astro:content';
import BaseLayout  from '../../layouts/BaseLayout.astro';
import Nav         from '../../components/layout/Nav.astro';
import Footer      from '../../components/layout/Footer.astro';
import FloatingWA  from '../../components/layout/FloatingWA.astro';
import { SITE, waLink } from '../../data/site';
import { tripEventSchema }  from '../../data/schemas/tripEvent';
import { breadcrumbSchema } from '../../data/schemas/breadcrumb';

export async function getStaticPaths() {
  const trips = await getCollection('trips');
  return trips.map((trip) => ({
    params: { slug: trip.data.slug },
    props:  { trip },
  }));
}

const { trip } = Astro.props;
const { data } = trip;

// Date formatting
const idMonths = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
const idMonthsShort = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agt','Sep','Okt','Nov','Des'];
const ds = data.dateStart;
const de = data.dateEnd;
const dateRangeShort = `${ds.getDate()}-${de.getDate()} ${idMonthsShort[ds.getMonth()]}`;
const dateRangeFull  = `${ds.getDate()}-${de.getDate()} ${idMonths[ds.getMonth()]} ${ds.getFullYear()}`;

const wa = waLink(data.destinationShort, dateRangeFull);
const isOpen = data.status === 'open';

const allFaqs = (await getCollection('faqs')).sort((a, b) => a.data.order - b.data.order);

// Schemas
const extraSchemas = [
  tripEventSchema({
    slug: data.slug,
    name: data.seo.title,
    description: data.seo.description,
    startDate: data.dateStart,
    endDate:   data.dateEnd,
    location:  data.destination,
    price:     data.pricing.earlyBird,
    status:    data.status,
  }),
  breadcrumbSchema([
    { name: 'Agenda 2026', url: `${SITE.url}/#agenda` },
    { name: data.destination, url: `${SITE.url}/trips/${data.slug}` },
  ]),
];

const fmtIDR = (n: number) => 'Rp ' + n.toLocaleString('id-ID');
const fmtIDRShort = (n: number) => {
  const juta = n / 1_000_000;
  return `Rp ${juta % 1 === 0 ? juta : juta.toFixed(2).replace(/\.?0+$/, '')}Jt`;
};
---

<BaseLayout
  title={data.seo.title}
  description={data.seo.description}
  ogImage={`${SITE.url}/images/og-default.png`}
  ogType="event"
  extraSchemas={extraSchemas}
>
  <Nav />

  <main id="main">

    <!-- HERO -->
    <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-jaga-bg">
      <div class="absolute inset-0 z-0 opacity-10 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-jaga-orange via-transparent to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 relative z-10 flex flex-col lg:flex-row items-center gap-16">
        <div class="lg:w-1/2 text-center lg:text-left">
          <span class="inline-block py-2 px-5 rounded-full bg-jaga-orange/10 text-jaga-orange font-bold text-sm md:text-base mb-6 tracking-widest uppercase shadow-sm">
            {data.hero.subtitle} · {data.category}
          </span>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-gray-900 tracking-tight leading-[1.1] mb-6">
            JAGATRIP TO <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-jaga-orange to-orange-400">
              {data.hero.titleHighlight}
            </span>
          </h1>

          <p class="text-xl md:text-2xl text-gray-700 mb-6 font-semibold">
            {data.hero.subtitle}
          </p>

          <p class="text-lg md:text-xl text-gray-500 mb-10 leading-relaxed">
            {data.hero.lead}
          </p>

          <a
            href={isOpen ? '#pricing' : wa}
            target={isOpen ? undefined : '_blank'}
            rel={isOpen ? undefined : 'noopener noreferrer'}
            class="inline-block bg-jaga-orange hover:bg-jaga-orange-600 text-white px-10 py-5 rounded-full font-bold text-lg shadow-[0_10px_30px_rgba(255,107,53,0.3)] hover:shadow-[0_15px_40px_rgba(255,107,53,0.4)] transition-all duration-300 transform hover:-translate-y-1"
          >
            {isOpen ? 'Amankan Kursi Sekarang' : 'Konsultasi via WhatsApp'}
          </a>
        </div>

        <div class="lg:w-1/2 w-full max-w-md mx-auto lg:max-w-none">
          <a
            href={wa}
            target="_blank"
            rel="noopener noreferrer"
            class="block relative w-full aspect-[4/5] rounded-[2.5rem] bg-white shadow-2xl border border-gray-100 overflow-hidden group"
          >
            <div class="absolute inset-0 bg-gradient-to-tr from-jaga-orange to-orange-300 opacity-10 group-hover:opacity-20 transition-opacity duration-500"></div>

            <div class="relative z-10 h-full flex flex-col justify-between p-10 md:p-12">
              <div class="flex items-center justify-between">
                <img src="/images/logo-icon.png" alt="" class="h-10 w-auto" />
                <span class="text-xs font-bold uppercase tracking-widest text-gray-400">Insider 2026</span>
              </div>

              <div class="text-center">
                <p class="text-sm font-bold uppercase tracking-[0.2em] text-jaga-orange mb-3">JAGATRIP TO</p>
                <h2 class="text-3xl md:text-4xl font-black text-gray-900 leading-none mb-4 break-words">
                  {data.destinationShort.toUpperCase()}
                </h2>
                <p class="text-3xl">{data.flag}</p>
              </div>

              <div>
                <div class="grid grid-cols-2 gap-2 mb-5 pb-5 border-b border-gray-200">
                  <div class="text-center">
                    <p class="text-2xl md:text-3xl font-black text-jaga-orange leading-none">{data.durationDays}</p>
                    <p class="text-xs font-bold uppercase tracking-wider text-gray-500 mt-1">Hari</p>
                  </div>
                  <div class="text-center border-l border-gray-200">
                    <p class="text-2xl md:text-3xl font-black text-jaga-orange leading-none">{data.itinerary.length}+</p>
                    <p class="text-xs font-bold uppercase tracking-wider text-gray-500 mt-1">Aktivitas</p>
                  </div>
                </div>
                <div class="flex items-end justify-between">
                  <div>
                    <p class="text-xs font-bold uppercase tracking-wider text-gray-500">Tanggal</p>
                    <p class="text-sm font-bold text-gray-900">{dateRangeFull}</p>
                  </div>
                  <div class="text-right">
                    <p class="text-xs font-bold uppercase tracking-wider text-gray-500">{isOpen && data.pricing.earlyBird ? 'Early Bird' : 'Harga'}</p>
                    <p class="text-2xl font-black text-jaga-orange">
                      {isOpen && data.pricing.earlyBird ? fmtIDRShort(data.pricing.earlyBird) : 'TBA'}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- TIMELINE / ITINERARY -->
    <section class="py-24 bg-white">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-20">
          <h2 class="text-4xl md:text-6xl font-black text-gray-900 mb-6 tracking-tight">
            {data.durationDays} Hari yang Bisa Mengubah <span class="text-jaga-orange">{data.durationDays} Tahun ke Depan</span> Sekolahmu.
          </h2>
          <p class="text-xl text-gray-600 font-medium">
            Selama {data.durationDays} hari{data.durationDays > 3 ? ' ' + (data.durationDays - 1) + ' malam' : ''}, kamu akan menjalani pengalaman yang tidak akan kamu temukan di seminar manapun, di buku manapun — karena ini nyata, langsung, dan personal.
          </p>
        </div>

        <div class="relative border-l-4 border-jaga-orange/30 ml-4 md:ml-10 space-y-16">
          {data.itinerary.map((day) => (
            <div class="relative pl-10 md:pl-16">
              <div class="absolute -left-[18px] md:-left-[22px] top-0 w-8 h-8 md:w-10 md:h-10 bg-jaga-orange rounded-full border-4 border-white shadow-lg flex items-center justify-center text-white font-bold text-sm md:text-base">
                {day.day}
              </div>
              <div class="bg-jaga-bg p-8 md:p-10 rounded-[2rem] shadow-sm border border-gray-100">
                <h3 class="text-xl md:text-2xl font-bold text-jaga-orange mb-2">
                  HARI {day.day} — {day.dayName}, {day.date.getDate()} {idMonths[day.date.getMonth()]} {day.date.getFullYear()}
                </h3>
                <h4 class="text-2xl md:text-3xl font-black text-gray-900 mb-6 uppercase tracking-wide">
                  {day.theme}
                </h4>
                <ul class="space-y-3">
                  {day.activities.map((activity) => (
                    <li class="flex items-start text-gray-700 text-lg font-medium">
                      <span class="text-jaga-orange mr-3">✔</span>
                      <span>{activity}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- BENEFITS (DARK) -->
    <section class="py-24 bg-gray-900 text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-jaga-orange opacity-10"></div>
      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <h2 class="text-4xl md:text-6xl font-black text-center mb-16 tracking-tight text-white">
          Yang Akan Kamu Dapatkan dari <span class="text-jaga-orange">JAGATRIP</span>
        </h2>

        <div class="grid md:grid-cols-2 gap-6 mb-20">
          {data.benefits.map((benefit) => (
            <div class="flex items-center bg-white/5 border border-white/10 p-6 rounded-2xl hover:bg-white/10 transition-colors">
              <p class="text-lg md:text-xl font-medium text-gray-100">
                <span aria-hidden="true">{benefit.icon}</span> {benefit.text}
              </p>
            </div>
          ))}
        </div>

        <div class="text-center max-w-5xl mx-auto bg-gradient-to-br from-jaga-orange to-orange-600 p-12 md:p-16 rounded-[3rem] shadow-2xl relative">
          <p class="text-3xl md:text-4xl lg:text-5xl font-black mb-0 italic leading-tight text-white relative z-10">
            "Perjalanan ini bukan pengeluaran. Ini adalah INVESTASI terbaik untuk sekolah dan generasi yang kamu didik."
          </p>
        </div>
      </div>
    </section>

    <!-- PRICING -->
    <section id="pricing" class="py-24 bg-jaga-bg border-t border-gray-200">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16 max-w-4xl mx-auto">
          <h2 class="text-4xl md:text-6xl font-black text-gray-900 mb-6 tracking-tight">
            Investasi Terbaik yang Pernah Kamu Buat untuk Sekolah dan Instansimu
          </h2>
        </div>

        <div class="grid lg:grid-cols-12 gap-10 items-start">
          <!-- Inclusions -->
          <div class="lg:col-span-7 bg-white p-8 md:p-12 rounded-[2.5rem] shadow-xl border border-gray-100">
            <p class="text-2xl text-gray-900 font-black mb-8 uppercase tracking-wide border-b border-gray-100 pb-4">
              PERJALANAN EDUKASI SUDAH TERMASUK:
            </p>

            <div class="grid sm:grid-cols-2 gap-4">
              {data.inclusions.map((item, i) => (
                <div class={`flex items-start bg-jaga-bg p-4 rounded-xl border border-gray-100 ${i === data.inclusions.length - 1 && data.inclusions.length % 2 === 1 ? 'sm:col-span-2' : ''}`}>
                  <span class="text-2xl mr-3 shrink-0" aria-hidden="true">{item.icon}</span>
                  <div>
                    <p class="text-gray-900 font-bold leading-tight">{item.label}</p>
                    <p class="text-gray-600 text-sm mt-1">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>

            {data.importantNote && (
              <div class="mt-8 p-6 bg-orange-50 rounded-2xl border border-orange-200">
                <p class="text-base text-gray-800 leading-relaxed">
                  <span class="font-bold text-jaga-orange uppercase mr-2">CATATAN PENTING:</span>
                  {data.importantNote}
                </p>
              </div>
            )}
          </div>

          <!-- Pricing cards -->
          <div class="lg:col-span-5 space-y-6">
            {isOpen && data.pricing.earlyBird ? (
              <>
                <div class="bg-gradient-to-br from-jaga-orange to-orange-500 p-10 md:p-12 rounded-[2.5rem] shadow-[0_20px_50px_rgba(255,107,53,0.3)] text-white transform hover:-translate-y-2 transition-transform duration-300 relative overflow-hidden border-4 border-white/20">
                  <div class="absolute top-0 right-0 bg-white text-jaga-orange font-black py-2 px-6 rounded-bl-2xl text-sm tracking-wider uppercase shadow-md">TERBATAS</div>
                  <h3 class="text-3xl font-black mb-2">🔥 EARLY BIRD</h3>
                  {data.earlyBirdDeadline && (
                    <p class="mb-8 text-orange-100 font-semibold text-lg border-b border-white/20 pb-4 inline-block">
                      Sampai {data.earlyBirdDeadline.getDate()} {idMonths[data.earlyBirdDeadline.getMonth()]} {data.earlyBirdDeadline.getFullYear()}
                    </p>
                  )}
                  <div class="text-5xl md:text-6xl font-black mb-2 tracking-tight">
                    {fmtIDRShort(data.pricing.earlyBird)} <span class="text-xl md:text-2xl font-bold text-orange-100">/ org</span>
                  </div>
                  <p class="text-lg md:text-xl font-bold mb-4 opacity-90">({fmtIDR(data.pricing.earlyBird)})</p>
                  <p class="text-base mb-10 text-orange-100 font-medium">All-in (sudah termasuk semua fasilitas)</p>
                  <a href={wa} target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-white text-jaga-orange font-black text-xl py-5 rounded-full shadow-xl hover:bg-gray-50 hover:scale-[1.02] transition-all">
                    DAFTAR SEKARANG
                  </a>
                </div>

                {data.pricing.normal && (
                  <div class="bg-white p-10 rounded-[2.5rem] shadow-lg border border-gray-200 flex justify-between items-center">
                    <div>
                      <h3 class="text-2xl font-bold text-gray-900 mb-1">HARGA NORMAL</h3>
                      <p class="text-gray-500 font-medium">
                        Berlaku setelah {data.earlyBirdDeadline ? `${data.earlyBirdDeadline.getDate()} ${idMonths[data.earlyBirdDeadline.getMonth()]} ${data.earlyBirdDeadline.getFullYear()}` : 'periode early bird'}
                      </p>
                    </div>
                    <div class="text-right">
                      <div class="text-3xl font-black text-gray-900">{fmtIDRShort(data.pricing.normal)}</div>
                      <div class="text-sm font-bold text-gray-500">({fmtIDR(data.pricing.normal)}) / orang</div>
                    </div>
                  </div>
                )}
              </>
            ) : (
              <div class="bg-gradient-to-br from-jaga-orange to-orange-500 p-10 md:p-12 rounded-[2.5rem] shadow-[0_20px_50px_rgba(255,107,53,0.3)] text-white">
                <h3 class="text-3xl font-black mb-3">🔜 HARGA SEGERA</h3>
                <p class="text-lg text-orange-50 mb-8 leading-relaxed font-medium">
                  Detail harga & paket untuk program {data.destination} akan diumumkan segera.
                  Hubungi admin untuk info lebih lanjut dan amankan slot lebih awal.
                </p>
                <a href={wa} target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-white text-jaga-orange font-black text-xl py-5 rounded-full shadow-xl hover:bg-gray-50 hover:scale-[1.02] transition-all">
                  HUBUNGI VIA WHATSAPP
                </a>
              </div>
            )}

            <p class="text-center text-sm md:text-base text-gray-500 font-medium leading-relaxed px-4">
              Kuota TERBATAS — Hanya untuk Peserta Serius yang Siap Level Up!
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-24 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 tracking-tight">
            FAQ (FREQUENTLY ASKED QUESTIONS)
          </h2>
          <p class="text-xl md:text-2xl text-gray-500 font-medium">
            Ada Pertanyaan? Kami Jawab Semuanya di Sini.
          </p>
        </div>

        <div class="divide-y divide-gray-200 border-y border-gray-200" id="trip-faq-accordion">
          {allFaqs.slice(0, 8).map((faq, i) => (
            <div class="trip-faq-item">
              <button
                class="trip-faq-trigger w-full flex items-center justify-between py-6 text-left gap-6"
                aria-expanded={i === 0 ? 'true' : 'false'}
                aria-controls={`trip-faq-answer-${i}`}
                id={`trip-faq-trigger-${i}`}
                type="button"
              >
                <span class="text-lg md:text-xl font-bold text-gray-900 leading-snug">
                  {faq.data.question}
                </span>
                <span
                  class={`trip-faq-icon shrink-0 w-9 h-9 rounded-full flex items-center justify-center font-bold text-xl transition-all duration-300 ${
                    i === 0 ? 'bg-jaga-orange text-white shadow-md' : 'bg-orange-100 text-jaga-orange'
                  }`}
                  aria-hidden="true"
                >
                  {i === 0 ? '×' : '+'}
                </span>
              </button>
              <div
                class="trip-faq-answer overflow-hidden transition-all duration-300"
                id={`trip-faq-answer-${i}`}
                role="region"
                aria-labelledby={`trip-faq-trigger-${i}`}
                style={i === 0 ? 'max-height: 400px; padding-bottom: 24px;' : 'max-height: 0;'}
              >
                <p class="text-gray-600 text-base md:text-lg leading-relaxed">{faq.data.answer}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center mt-12">
          <a href="/faq" class="inline-block text-jaga-orange font-bold hover:underline">
            Lihat Semua FAQ →
          </a>
        </div>
      </div>
    </section>

    <!-- CTA BANNER -->
    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="bg-jaga-orange rounded-[2rem] p-8 md:p-14 flex flex-col md:flex-row items-center justify-between shadow-xl">
          <div class="text-white mb-8 md:mb-0 md:pr-8 text-center md:text-left">
            <h2 class="text-3xl md:text-4xl font-bold mb-3 tracking-tight">JANGAN TUNDA LAGI! Kursi Terbatas</h2>
            <p class="text-orange-50 text-lg md:text-xl font-medium">Daftar Sekarang Sebelum Penuh</p>
          </div>
          <div class="shrink-0 w-full md:w-auto">
            <a
              href={wa}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center w-full md:w-auto bg-white text-jaga-orange font-bold text-lg px-8 py-4 rounded-full shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1 whitespace-nowrap"
            >
              Daftar Sekarang
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingWA />
</BaseLayout>

<script>
  const tripItems = document.querySelectorAll<HTMLElement>('.trip-faq-item');
  tripItems.forEach((item) => {
    const btn    = item.querySelector<HTMLButtonElement>('.trip-faq-trigger')!;
    const answer = item.querySelector<HTMLElement>('.trip-faq-answer')!;
    const icon   = item.querySelector<HTMLElement>('.trip-faq-icon')!;
    if (!btn) return;

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      tripItems.forEach((other) => {
        const ob = other.querySelector<HTMLButtonElement>('.trip-faq-trigger')!;
        const oa = other.querySelector<HTMLElement>('.trip-faq-answer')!;
        const oi = other.querySelector<HTMLElement>('.trip-faq-icon')!;
        if (!ob) return;
        ob.setAttribute('aria-expanded', 'false');
        oa.style.maxHeight = '0';
        oa.style.paddingBottom = '0';
        oi.textContent = '+';
        oi.classList.remove('bg-jaga-orange', 'text-white', 'shadow-md');
        oi.classList.add('bg-orange-100', 'text-jaga-orange');
      });
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        answer.style.paddingBottom = '24px';
        icon.textContent = '×';
        icon.classList.remove('bg-orange-100', 'text-jaga-orange');
        icon.classList.add('bg-jaga-orange', 'text-white', 'shadow-md');
      }
    });
  });
</script>
