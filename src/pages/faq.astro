---
import BaseLayout  from '../layouts/BaseLayout.astro';
import Nav         from '../components/layout/Nav.astro';
import Footer      from '../components/layout/Footer.astro';
import FloatingWA  from '../components/layout/FloatingWA.astro';
import { getCollection } from 'astro:content';
import { SITE, waLink }  from '../data/site';
import { faqPageSchema }    from '../data/schemas/faqPage';
import { breadcrumbSchema } from '../data/schemas/breadcrumb';

const wa = waLink();
const allFaqs = (await getCollection('faqs')).sort((a, b) => a.data.order - b.data.order);

const categories = [
  { key: 'semua',       label: 'Semua' },
  { key: 'umum',        label: 'Umum' },
  { key: 'pendaftaran', label: 'Pendaftaran' },
  { key: 'paket',       label: 'Paket' },
  { key: 'pembayaran',  label: 'Pembayaran' },
  { key: 'persiapan',   label: 'Persiapan' },
  { key: 'kebijakan',   label: 'Kebijakan' },
];

const extraSchemas = [
  faqPageSchema(allFaqs.map((f) => ({ question: f.data.question, answer: f.data.answer }))),
  breadcrumbSchema([{ name: 'FAQ', url: `${SITE.url}/faq` }]),
];
---

<BaseLayout
  title="FAQ JAGATRIP — Pertanyaan Umum Program Edu-Tourism"
  description="Temukan jawaban atas pertanyaan umum tentang program JAGATRIP: pendaftaran, paket, pembayaran, persiapan, kebijakan."
  extraSchemas={extraSchemas}
>
  <Nav />

  <main id="main">

    <!-- HERO -->
    <section class="relative pt-32 pb-16 lg:pt-40 lg:pb-20 overflow-hidden bg-jaga-bg">
      <div class="absolute inset-0 z-0 opacity-10 bg-[radial-gradient(circle_at_top_right,var(--tw-gradient-stops))] from-jaga-orange via-transparent to-transparent"></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
        <span class="inline-block py-2 px-5 rounded-full bg-jaga-orange/10 text-jaga-orange font-bold text-sm md:text-base mb-6 tracking-widest uppercase shadow-sm">
          Bantuan
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-gray-900 tracking-tight leading-[1.1] mb-6">
          FAQ <span class="text-transparent bg-clip-text bg-linear-to-r from-jaga-orange to-orange-400">(Frequently Asked Questions)</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-500 font-medium">
          Ada Pertanyaan? Kami Jawab Semuanya di Sini.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-4xl mx-auto px-6">

        <!-- Category filter -->
        <div
          id="faq-filter"
          class="flex flex-wrap gap-3 mb-12 justify-center"
          role="tablist"
          aria-label="Filter FAQ"
        >
          {categories.map((cat) => (
            <button
              data-filter={cat.key}
              role="tab"
              aria-selected={cat.key === 'semua' ? 'true' : 'false'}
              type="button"
              class={`px-5 py-2 rounded-full font-bold text-sm border-2 transition-all ${
                cat.key === 'semua'
                  ? 'bg-jaga-orange text-white border-jaga-orange shadow-md'
                  : 'bg-white text-gray-600 border-gray-200 hover:border-jaga-orange hover:text-jaga-orange'
              }`}
            >
              {cat.label}
            </button>
          ))}
        </div>

        <!-- FAQ list (accordion) -->
        <div id="faq-list" class="divide-y divide-gray-200 border-y border-gray-200">
          {allFaqs.map((faq, i) => (
            <div
              class="page-faq-item"
              data-category={faq.data.category}
              id={faq.data.id}
            >
              <button
                class="page-faq-trigger w-full flex items-center justify-between py-6 text-left gap-6"
                aria-expanded={i === 0 ? 'true' : 'false'}
                aria-controls={`page-faq-answer-${i}`}
                id={`page-faq-trigger-${i}`}
                type="button"
              >
                <span class="text-lg md:text-xl font-bold text-gray-900 leading-snug">
                  {faq.data.question}
                </span>
                <span
                  class={`page-faq-icon shrink-0 w-9 h-9 rounded-full flex items-center justify-center font-bold text-xl transition-all duration-300 ${
                    i === 0 ? 'bg-jaga-orange text-white shadow-md' : 'bg-orange-100 text-jaga-orange'
                  }`}
                  aria-hidden="true"
                >
                  {i === 0 ? '×' : '+'}
                </span>
              </button>
              <div
                class="page-faq-answer overflow-hidden transition-all duration-300"
                id={`page-faq-answer-${i}`}
                role="region"
                aria-labelledby={`page-faq-trigger-${i}`}
                style={i === 0 ? 'max-height: 400px; padding-bottom: 24px;' : 'max-height: 0;'}
              >
                <p class="text-gray-600 text-base md:text-lg leading-relaxed">{faq.data.answer}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <div class="text-center mt-16 p-10 bg-jaga-bg rounded-4xl border border-gray-100">
          <p class="text-2xl font-bold text-gray-900 mb-3">Masih ada pertanyaan lain?</p>
          <p class="text-gray-600 mb-6">Tim admin JAGATRIP siap membantu kamu langsung via WhatsApp.</p>
          <a
            href={wa}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-full sm:w-auto bg-jaga-orange hover:bg-jaga-orange-600 text-white px-10 py-4 rounded-full font-bold text-lg shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1"
          >
            💬 Chat WhatsApp Sekarang
          </a>
        </div>

      </div>
    </section>

  </main>

  <Footer />
  <FloatingWA />
</BaseLayout>

<script>
  // ── Category filter ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const faqItems   = document.querySelectorAll<HTMLElement>('.page-faq-item');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      filterBtns.forEach((b) => {
        b.classList.remove('bg-jaga-orange', 'text-white', 'border-jaga-orange', 'shadow-md');
        b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
      btn.classList.add('bg-jaga-orange', 'text-white', 'border-jaga-orange', 'shadow-md');
      btn.setAttribute('aria-selected', 'true');

      faqItems.forEach((item) => {
        const cat = item.dataset.category!;
        item.style.display = (filter === 'semua' || cat === filter) ? 'block' : 'none';
      });
    });
  });

  // ── Accordion ──
  faqItems.forEach((item) => {
    const btn    = item.querySelector<HTMLButtonElement>('.page-faq-trigger')!;
    const answer = item.querySelector<HTMLElement>('.page-faq-answer')!;
    const icon   = item.querySelector<HTMLElement>('.page-faq-icon')!;
    if (!btn) return;

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      // Close all visible
      faqItems.forEach((other) => {
        if (other.style.display === 'none') return;
        const ob = other.querySelector<HTMLButtonElement>('.page-faq-trigger')!;
        const oa = other.querySelector<HTMLElement>('.page-faq-answer')!;
        const oi = other.querySelector<HTMLElement>('.page-faq-icon')!;
        if (!ob) return;
        ob.setAttribute('aria-expanded', 'false');
        oa.style.maxHeight = '0';
        oa.style.paddingBottom = '0';
        oi.textContent = '+';
        oi.classList.remove('bg-jaga-orange', 'text-white', 'shadow-md');
        oi.classList.add('bg-orange-100', 'text-jaga-orange');
      });
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        answer.style.paddingBottom = '24px';
        icon.textContent = '×';
        icon.classList.remove('bg-orange-100', 'text-jaga-orange');
        icon.classList.add('bg-jaga-orange', 'text-white', 'shadow-md');
      }
    });
  });
</script>
