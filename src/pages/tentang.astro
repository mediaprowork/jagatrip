---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav        from '../components/layout/Nav.astro';
import Footer     from '../components/layout/Footer.astro';
import FloatingWA from '../components/layout/FloatingWA.astro';
import { SITE } from '../data/site';
import { breadcrumbSchema } from '../data/schemas/breadcrumb';

const extraSchemas = [
  breadcrumbSchema([{ name: 'Tentang', url: `${SITE.url}/tentang` }]),
];
---

<BaseLayout
  title="Tentang JAGATRIP — PT Jagatrip Mitra Edukasi"
  description="Kenali lebih dekat JAGATRIP, program Edu-Tourism premium untuk praktisi pendidikan Indonesia."
  extraSchemas={extraSchemas}
>
  <Nav />

  <main id="main">

    <!-- HERO -->
    <section class="relative pt-32 pb-16 lg:pt-40 lg:pb-20 overflow-hidden bg-jaga-bg">
      <div class="absolute inset-0 z-0 opacity-10 bg-[radial-gradient(circle_at_top_right,var(--tw-gradient-stops))] from-jaga-orange via-transparent to-transparent"></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
        <span class="inline-block py-2 px-5 rounded-full bg-jaga-orange/10 text-jaga-orange font-bold text-sm md:text-base mb-6 tracking-widest uppercase shadow-sm">
          Tentang Kami
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-gray-900 tracking-tight leading-[1.1] mb-6">
          Siapa Itu <span class="text-transparent bg-clip-text bg-linear-to-r from-jaga-orange to-orange-400">JAGATRIP?</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed">
          Program Edu-Tourism premium yang dirancang khusus untuk praktisi pendidikan Indonesia
          yang ingin berkembang bersama melalui benchmarking ke sekolah-sekolah terbaik dunia.
        </p>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="py-24 bg-white">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-12 items-start">
          <div>
            <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-6 tracking-tight">
              Bukan Travel Biasa — <span class="text-jaga-orange">Ini Misi Pendidikan.</span>
            </h2>
            <p class="text-lg text-gray-600 leading-relaxed mb-4">
              JAGATRIP lahir dari keyakinan bahwa praktisi pendidikan Indonesia berhak mendapatkan
              akses ke wawasan dan pengalaman terbaik dunia. Kami memfasilitasi benchmarking langsung
              ke sekolah-sekolah top, bukan sekadar wisata — tapi perjalanan edukasi yang mengubah perspektif.
            </p>
            <p class="text-lg text-gray-600 leading-relaxed">
              Berdiri tahun 2026, JAGATRIP bermitra dengan <strong>Alfatihah Tour & Travel</strong> sebagai
              operator perjalanan resmi. Kami menggabungkan keahlian pendidikan dengan layanan travel premium.
            </p>
          </div>

          <div class="grid grid-cols-3 gap-4">
            <div class="bg-jaga-bg p-5 rounded-2xl border border-gray-100 text-center">
              <p class="text-3xl md:text-4xl font-black text-jaga-orange leading-none">7+</p>
              <p class="text-xs font-bold uppercase tracking-wider text-gray-500 mt-2">Destinasi</p>
            </div>
            <div class="bg-jaga-bg p-5 rounded-2xl border border-gray-100 text-center">
              <p class="text-3xl md:text-4xl font-black text-jaga-orange leading-none">500+</p>
              <p class="text-xs font-bold uppercase tracking-wider text-gray-500 mt-2">Alumni</p>
            </div>
            <div class="bg-jaga-bg p-5 rounded-2xl border border-gray-100 text-center">
              <p class="text-3xl md:text-4xl font-black text-jaga-orange leading-none">100%</p>
              <p class="text-xs font-bold uppercase tracking-wider text-gray-500 mt-2">Safety</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- VISI MISI -->
    <section class="py-24 bg-jaga-bg">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight">
            Visi & <span class="text-jaga-orange">Misi</span>
          </h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white p-10 rounded-4xl shadow-sm border border-gray-100">
            <div class="text-4xl mb-6" aria-hidden="true">🌏</div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Visi</h3>
            <p class="text-gray-600 text-lg leading-relaxed">
              Menjadi platform benchmarking pendidikan terdepan yang menghubungkan praktisi pendidikan
              Indonesia dengan standar dan praktik terbaik pendidikan global.
            </p>
          </div>
          <div class="bg-white p-10 rounded-4xl shadow-sm border border-gray-100">
            <div class="text-4xl mb-6" aria-hidden="true">🎯</div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Misi</h3>
            <ul class="text-gray-600 text-lg leading-relaxed space-y-2">
              <li class="flex gap-3"><span class="text-jaga-orange shrink-0">→</span> Memfasilitasi benchmarking langsung ke sekolah terbaik dunia</li>
              <li class="flex gap-3"><span class="text-jaga-orange shrink-0">→</span> Membangun komunitas praktisi pendidikan Indonesia yang kuat</li>
              <li class="flex gap-3"><span class="text-jaga-orange shrink-0">→</span> Mendorong inovasi dan transformasi pendidikan dari akar rumput</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingWA />
</BaseLayout>
